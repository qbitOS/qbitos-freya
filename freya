    "ollama": {
        "llama2": "llama2",
        "llama3": "llama3.1",
        "mistral": "mistral",
        "falcon": "falcon",
        "gptneo": "gpt-neo",
        "codellama": "codellama",
        "vicuna": "vicuna",
    },
    "huggingface": {
        "llama2": "meta-llama/Llama-2-7b-chat-hf",
        "llama3": "meta-llama/Llama-3.1-8B-Instruct",
        "mistral": "mistralai/Mistral-7B-Instruct-v0.3",
        "falcon": "tiiuae/falcon-7b-instruct",
        "gptneo": "EleutherAI/gpt-neo-2.7B",
        "codellama": "meta-llama/CodeLlama-7b-Instruct-hf",
        "vicuna": "lmsys/vicuna-7b-v1.5",
    },
    "lmstudio": {
        "llama2": "llama-2",
        "llama3": "llama-3",
        "mistral": "mistral",
        "falcon": "falcon",
        "gptneo": "gpt-neo",
        "codellama": "codellama",
        "vicuna": "vicuna",
    },
