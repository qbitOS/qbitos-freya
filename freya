"""Unified Freya CLI for math, conversions, and multi-backend chat."""

from __future__ import annotations

import argparse
import importlib.util
import json
import os
import sys
import urllib.error
import urllib.request
from pathlib import Path

# Import math helpers from existing CLI module.
spec = importlib.util.spec_from_file_location(
    "freya_math_cli",
    str(Path(__file__).parent / "tools" / "freya-math-cli.py"),
)
freya_math_cli = importlib.util.module_from_spec(spec)
spec.loader.exec_module(freya_math_cli)

data_economics = freya_math_cli.data_economics
eval_expr = freya_math_cli.eval_expr

SUPPORTED_FAMILIES = {
    "llama2",
    "llama3",
    "mistral",
    "falcon",
    "gptneo",
    "codellama",
    "vicuna",
}

