def _plugin_resolve(name: str, include_optional: bool = False) -> dict:
    idx = _plugin_discover()
    plugins = idx.get("plugins", [])
    by_name = {str(p.get("name")): p for p in plugins if isinstance(p, dict)}
    if name not in by_name:
        raise ValueError(f"plugin not found in index: {name}")
    ordered = []
    seen = set()

    def walk(n: str) -> None:
        if n in seen:
            return
        seen.add(n)
        p = by_name.get(n, {"name": n, "dependencies": []})
        deps = p.get("dependencies", []) if isinstance(p, dict) else []
        if not isinstance(deps, list):
            deps = []
        for d in deps:
            walk(str(d))
        if include_optional and isinstance(p, dict):
            for d in p.get("optionalDependencies", []) if isinstance(p.get("optionalDependencies", []), list) else []:
                walk(str(d))
        ordered.append(n)

    walk(name)
    installed = _load_json_file(FREYA_PLUGIN_REGISTRY_PATH, {"plugins": []})
    plist = installed.get("plugins", []) if isinstance(installed, dict) else []
    have = {str(p.get("name")) for p in plist if isinstance(p, dict)}
    missing = [n for n in ordered if n not in have]
    return {"plugin": name, "installOrder": ordered, "missing": missing, "alreadyInstalled": [n for n in ordered if n in have]}


