def _validate_ruleset_obj(obj: dict) -> list[str]:
    issues: list[str] = []
    if not isinstance(obj, dict):
        return ["ruleset must be a JSON object"]
    if not isinstance(obj.get("version"), str):
        issues.append("version must be string")
    if not isinstance(obj.get("name"), str):
        issues.append("name must be string")
    if not isinstance(obj.get("enforce"), bool):
        issues.append("enforce must be boolean")
    cp = obj.get("chunkPolicy")
    if not isinstance(cp, dict):
        issues.append("chunkPolicy must be object")
    else:
        if not isinstance(cp.get("allowAll"), bool):
            issues.append("chunkPolicy.allowAll must be boolean")
        if not isinstance(cp.get("denyChunks"), list):
            issues.append("chunkPolicy.denyChunks must be array")
        if not isinstance(cp.get("maxBenchIterations"), int):
            issues.append("chunkPolicy.maxBenchIterations must be int")
        if not isinstance(cp.get("allowDockerBuild"), bool):
            issues.append("chunkPolicy.allowDockerBuild must be boolean")
    pp = obj.get("pluginPolicy")
    if not isinstance(pp, dict):
        issues.append("pluginPolicy must be object")
    else:
        if not isinstance(pp.get("allowSandboxProfiles"), list):
            issues.append("pluginPolicy.allowSandboxProfiles must be array")
        if not isinstance(pp.get("denyNamePatterns"), list):
            issues.append("pluginPolicy.denyNamePatterns must be array")
    return issues


def _load_active_ruleset() -> dict:
    if FREYA_ACTIVE_RULESET_PATH.exists():
        obj = _load_json_file(FREYA_ACTIVE_RULESET_PATH, _default_ruleset())
        if isinstance(obj, dict):
            return obj
    return _default_ruleset()


def _save_active_ruleset(ruleset: dict) -> None:
    _save_json_file(FREYA_ACTIVE_RULESET_PATH, ruleset)


def _enforce_ruleset_for_chunk(chunk_id: str, args: argparse.Namespace) -> None:
    rules = _load_active_ruleset()
    if not rules.get("enforce", True):
        return
    cp = rules.get("chunkPolicy", {})
    deny = set(cp.get("denyChunks", []))
    if chunk_id in deny:
        raise ValueError(f"chunk '{chunk_id}' blocked by active ruleset")
    if not cp.get("allowAll", True):
        raise ValueError("chunk execution blocked: allowAll=false in active ruleset")
    if chunk_id == "bench.run":
        max_iter = int(cp.get("maxBenchIterations", 10000))
        if int(args.iterations) > max_iter:
            raise ValueError(f"bench iterations exceed ruleset limit ({args.iterations}>{max_iter})")
    if chunk_id == "docker.build" and not bool(cp.get("allowDockerBuild", False)):
        raise ValueError("docker.build blocked by ruleset (allowDockerBuild=false)")


def _sanitize_plugin_name(name: str) -> str:
    out = re.sub(r"[^a-zA-Z0-9._-]+", "-", name.strip())
    return out.strip(".-") or "plugin"


def _plugin_allowed_by_ruleset(name: str, sandbox: str) -> tuple[bool, str]:
    rules = _load_active_ruleset()
    pp = rules.get("pluginPolicy", {})
    allowed_profiles = set(pp.get("allowSandboxProfiles", ["strict", "standard", "trusted"]))
    if sandbox not in allowed_profiles:
        return False, f"sandbox profile '{sandbox}' not allowed by ruleset"
    deny_patterns = [str(x) for x in pp.get("denyNamePatterns", [])]
    for pat in deny_patterns:
        if pat and pat in name:
            return False, f"plugin name matches denied pattern '{pat}'"
    return True, ""


def _append_artifact(kind: str, name: str, path: str | None, meta: dict | None = None, lifecycle: str = "active") -> dict:
    _ensure_state_dir()
    payload = _load_json_file(FREYA_ARTIFACT_INDEX_PATH, {"version": "1.0.0", "artifacts": []})
    if not isinstance(payload, dict):
        payload = {"version": "1.0.0", "artifacts": []}
    artifacts = payload.get("artifacts", [])
    if not isinstance(artifacts, list):
        artifacts = []
    artifact_id = _sha256_text(f"{kind}:{name}:{path or ''}:{time.time_ns()}")[:16]
    item = {
        "id": artifact_id,
        "kind": kind,
        "name": name,
        "path": path,
        "version": "0.1.0",
        "lifecycle": lifecycle,
        "createdAt": _now_iso(),
        "updatedAt": _now_iso(),
        "meta": meta or {},
    }
    artifacts.append(item)
    payload["artifacts"] = artifacts
    _save_json_file(FREYA_ARTIFACT_INDEX_PATH, payload)
    return item


def _artifact_track_chunk_result(chunk_id: str, result: dict) -> None:
    if not isinstance(result, dict):
        return
    for key in ["output", "storedPath", "path"]:
        val = result.get(key)
        if isinstance(val, str) and val.strip():
            _append_artifact(
                kind="chunk-output",
                name=f"{chunk_id}:{key}",
                path=val,
                meta={"chunkId": chunk_id, "status": result.get("status", "unknown")},
            )


def _artifact_list(kind: str | None = None, lifecycle: str | None = None) -> dict:
    payload = _load_json_file(FREYA_ARTIFACT_INDEX_PATH, {"version": "1.0.0", "artifacts": []})
    artifacts = payload.get("artifacts", []) if isinstance(payload, dict) else []
    if not isinstance(artifacts, list):
        artifacts = []
    out = []
    for item in artifacts:
        if not isinstance(item, dict):
            continue
        if kind and item.get("kind") != kind:
            continue
        if lifecycle and item.get("lifecycle") != lifecycle:
            continue
        out.append(item)
    return {"count": len(out), "artifacts": out}


def _artifact_set_lifecycle(artifact_id: str, lifecycle: str) -> dict:
    payload = _load_json_file(FREYA_ARTIFACT_INDEX_PATH, {"version": "1.0.0", "artifacts": []})
    artifacts = payload.get("artifacts", []) if isinstance(payload, dict) else []
    for item in artifacts:
        if isinstance(item, dict) and item.get("id") == artifact_id:
            item["lifecycle"] = lifecycle
            item["updatedAt"] = _now_iso()
            _save_json_file(FREYA_ARTIFACT_INDEX_PATH, payload)
            return {"status": "PASS", "artifact": item}
    raise ValueError(f"artifact id not found: {artifact_id}")


def _rag_tokenize(text: str) -> list[str]:
    return [t for t in re.split(r"[^a-zA-Z0-9_]+", text.lower()) if t]


def _rag_index_paths(base: Path, include_glob: str) -> list[Path]:
    if base.is_file():
        return [base]
    files = []
    for p in base.rglob(include_glob):
        if p.is_file():
            files.append(p)
    return sorted(files)


def _rag_build(source: str, include_glob: str = "*.md", max_chars: int = 200000) -> dict:
    base = Path(source)
    if not base.exists():
        raise ValueError(f"source path not found: {source}")
    docs = []
    for path in _rag_index_paths(base, include_glob):
        try:
            txt = path.read_text(encoding="utf-8")
        except Exception:  # noqa: BLE001
            continue
        txt = txt[:max_chars]
        tokens = _rag_tokenize(txt)
        docs.append(
            {
                "id": _sha256_text(str(path))[:16],
                "path": str(path),
                "tokenCount": len(tokens),
                "text": txt,
            }
        )
    out = {"version": "1.0.0", "builtAt": _now_iso(), "source": str(base), "glob": include_glob, "docs": docs}
    _save_json_file(FREYA_RAG_INDEX_PATH, out)
    return {"status": "PASS", "docs": len(docs), "path": str(FREYA_RAG_INDEX_PATH)}


def _rag_query(query: str, top_k: int = 5) -> dict:
    index = _load_json_file(FREYA_RAG_INDEX_PATH, {"docs": []})
    docs = index.get("docs", []) if isinstance(index, dict) else []
    q_tokens = _rag_tokenize(query)
    q_set = set(q_tokens)
    scored = []
    for doc in docs:
        if not isinstance(doc, dict):
            continue
        text = str(doc.get("text", ""))
        t_set = set(_rag_tokenize(text))
        score = len(q_set.intersection(t_set))
        if score <= 0:
            continue
        snippet = text[:220].replace("\n", " ")
        scored.append({"path": doc.get("path"), "score": score, "snippet": snippet})
    scored.sort(key=lambda x: x["score"], reverse=True)
    return {"query": query, "topK": top_k, "results": scored[: max(1, top_k)]}


def _session_path(session_id: str) -> Path:
    safe = re.sub(r"[^a-zA-Z0-9._-]+", "-", session_id.strip())
    return FREYA_SESSION_DIR / f"{safe}.json"


def _session_list(status: str | None = None) -> dict:
    _ensure_state_dir()
    items = []
    for p in sorted(FREYA_SESSION_DIR.glob("*.json")):
        obj = _load_json_file(p, {})
        if not isinstance(obj, dict):
            continue
        st = str(obj.get("status", "active"))
        if status and st != status:
            continue
        turns = obj.get("turns", [])
        items.append(
            {
                "sessionId": obj.get("sessionId", p.stem),
                "status": st,
                "turns": len(turns) if isinstance(turns, list) else 0,
                "updatedAt": obj.get("updatedAt"),
                "path": str(p),
            }
        )
    return {"count": len(items), "sessions": items}


def _session_show(session_id: str) -> dict:
    sp = _session_path(session_id)
    if not sp.exists():
        raise ValueError(f"session not found: {session_id}")
    obj = _load_json_file(sp, {})
    if not isinstance(obj, dict):
        raise ValueError("invalid session payload")
    return obj


def _session_set_status(session_id: str, status: str) -> dict:
    sp = _session_path(session_id)
    if not sp.exists():
        raise ValueError(f"session not found: {session_id}")
    obj = _load_json_file(sp, {})
    if not isinstance(obj, dict):
        obj = {"sessionId": session_id, "turns": []}
    obj["status"] = status
    obj["updatedAt"] = _now_iso()
    _save_json_file(sp, obj)
    return {"status": "PASS", "sessionId": session_id, "sessionStatus": status}


def _session_delete(session_id: str) -> dict:
    sp = _session_path(session_id)
    if not sp.exists():
        raise ValueError(f"session not found: {session_id}")
    sp.unlink()
    return {"status": "PASS", "deleted": session_id}


