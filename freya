def _chunk_telemetry_stream(args: argparse.Namespace) -> dict:
    if not args.input:
        raise ValueError("telemetry.stream requires --input")
    rows = _load_telemetry_input(args.input, args.input_format)
    rows, summary = _annotate_telemetry_rows(
        rows=rows,
        step_sec=max(0.001, args.step_sec),
        maxq_start_sec=args.phase_maxq_start_sec,
        maxq_end_sec=args.phase_maxq_end_sec,
        meco_sec=args.phase_meco_sec,
        seco_sec=args.phase_seco_sec,
    )
    replay = max(0.001, args.replay_speed)
    if args.live:
        prev_t = None
        for row in rows:
            print(json.dumps(row, ensure_ascii=True))
            t_now = _to_float(row.get("tSec"), 0.0)
            if prev_t is not None:
                dt = max(0.0, t_now - prev_t)
                time.sleep(dt / replay)
            prev_t = t_now
        print(json.dumps({"summary": summary}, ensure_ascii=True))
    return {
        "chunk": "telemetry.stream",
        "status": "PASS",
        "mode": "live-stdout" if args.live else "dry-run",
        "rows": len(rows),
        "replaySpeed": replay,
        "streamPort": args.stream_port,
        "summary": summary,
    }


def _chunk_quantum_algorithm(args: argparse.Namespace) -> dict:
    name = (args.name or "").strip().lower()
    if name == "grover":
        program = _build_quantum_preset_program("grover2", 2, args.marked_state)
        return {
            "chunk": "quantum.algorithm",
            "algorithm": "grover",
            "note": "Current implementation uses 2-qubit Grover preset.",
            "result": _run_quantum_program(2, program, max(0, args.shots)),
        }
    if name == "shor":
        n = int(args.number)
        if n < 2:
            raise ValueError("shor requires --number >= 2")
        factor = 1
        for i in range(2, int(math.sqrt(n)) + 1):
            if n % i == 0:
                factor = i
                break
        if factor == 1:
            return {
                "chunk": "quantum.algorithm",
                "algorithm": "shor",
                "status": "INCONCLUSIVE",
                "number": n,
                "message": "No non-trivial factor found (likely prime) in classical fallback.",
            }
        return {
            "chunk": "quantum.algorithm",
            "algorithm": "shor",
            "status": "PASS",
            "number": n,
            "factors": [factor, n // factor],
            "message": "Classical fallback factorization for CLI portability.",
        }
    raise ValueError(f"unsupported quantum algorithm '{name}'")


def _chunk_gis_convert(args: argparse.Namespace) -> dict:
    from_crs = (args.from_crs or "").upper()
    to_crs = (args.to_crs or "").upper()
    lat = float(args.lat)
    lon = float(args.lon)
    if from_crs == "WGS84" and to_crs in {"WEBMERCATOR", "EPSG:3857"}:
        r = 6378137.0
        x = math.radians(lon) * r
        y = math.log(math.tan((math.pi / 4) + (math.radians(lat) / 2))) * r
        return {"chunk": "gis.convert", "from": from_crs, "to": to_crs, "x": x, "y": y}
    if from_crs == "WGS84" and to_crs == "UTM":
        zone = int((lon + 180) / 6) + 1
        return {
            "chunk": "gis.convert",
            "from": "WGS84",
            "to": "UTM",
            "zone": zone,
            "hemisphere": "N" if lat >= 0 else "S",
            "note": "Use pyproj for survey-grade UTM precision; this CLI chunk is a routing stub.",
        }
    raise ValueError("supported conversions: WGS84->WEBMERCATOR and WGS84->UTM")


