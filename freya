        if args.math_cmd == "expr":
            try:
                print(eval_expr(args.expression))
                return 0
            except Exception as exc:  # noqa: BLE001
                print(f"error: {exc}", file=sys.stderr)
                return 1

    if args.cmd == "chat":
        query = " ".join(args.query)
        out = chat_conversion(query, backend=args.backend, model=args.model, family=args.family)
        print(out)
        return 0 if not out.startswith("Error:") else 1
    if args.cmd == "models":
        print(json.dumps(models_inventory(args.backend), indent=2))
        return 0
    if args.cmd == "telemetry":
        try:
            if args.input:
                rows = _load_telemetry_input(args.input, args.input_format)
                rows, summary = _annotate_telemetry_rows(
                    rows=rows,
                    step_sec=max(0.001, args.step_sec),
                    maxq_start_sec=args.phase_maxq_start_sec,
                    maxq_end_sec=args.phase_maxq_end_sec,
                    meco_sec=args.phase_meco_sec,
                    seco_sec=args.phase_seco_sec,
                )
            else:
                required = {
                    "--dry-mass-kg": args.dry_mass_kg,
                    "--fuel-mass-kg": args.fuel_mass_kg,
                    "--thrust-n": args.thrust_n,
                    "--isp-s": args.isp_s,
                }
                missing = [flag for flag, value in required.items() if value is None]
                if missing:
                    raise ValueError(f"missing required args for simulation: {', '.join(missing)}")
                rows, sim_summary = _simulate_telemetry(
                    duration_s=args.duration_sec,
                    dt_s=args.step_sec,
                    dry_mass_kg=float(args.dry_mass_kg),
                    fuel_mass_kg=float(args.fuel_mass_kg),
                    thrust_n=float(args.thrust_n),
                    isp_s=float(args.isp_s),
                    drag_cd=args.cd,
                    area_m2=args.area_m2,
                    throttle=max(0.0, min(1.0, args.throttle)),
                    live=False,
                )
                rows, summary = _annotate_telemetry_rows(
                    rows=rows,
                    step_sec=max(0.001, args.step_sec),
                    maxq_start_sec=args.phase_maxq_start_sec,
                    maxq_end_sec=args.phase_maxq_end_sec,
                    meco_sec=args.phase_meco_sec,
                    seco_sec=args.phase_seco_sec,
                )
                summary["deltaVVacuumMs"] = sim_summary.get("deltaVVacuumMs", 0.0)

            if args.jsonl:
                replay = max(0.001, args.replay_speed)
                prev_t = None
                for row in rows:
                    print(json.dumps(row, ensure_ascii=True))
                    if args.live:
                        t_now = _to_float(row.get("tSec"), 0.0)
                        if prev_t is None:
                            prev_t = t_now
                        else:
                            dt = max(0.0, t_now - prev_t)
                            prev_t = t_now
                            time.sleep(dt / replay)
                print(json.dumps({"summary": summary}, ensure_ascii=True))
            else:
                print(json.dumps({"summary": summary, "final": rows[-1], "samples": rows[:3]}, indent=2))
            return 0
        except Exception as exc:  # noqa: BLE001
            print(f"error: {exc}", file=sys.stderr)
            return 1
    if args.cmd == "telemetry-validate":
        try:
            raw_rows = _load_telemetry_input(args.input, args.input_format)
            rows, summary = _annotate_telemetry_rows(
                rows=raw_rows,
                step_sec=max(0.001, args.step_sec),
                maxq_start_sec=args.phase_maxq_start_sec,
                maxq_end_sec=args.phase_maxq_end_sec,
                meco_sec=args.phase_meco_sec,
                seco_sec=args.phase_seco_sec,
            )
            report = _validate_telemetry(
                rows=rows,
                summary=summary,
                max_q_kpa=args.max_q_kpa,
                max_accel_g=args.max_accel_g,
                min_twr=args.min_twr_powered,
                max_thermal=args.max_thermal_proxy,
            )
            print(json.dumps(report, indent=2))
            return 0 if report["status"] == "PASS" else 2
        except Exception as exc:  # noqa: BLE001
            print(f"error: {exc}", file=sys.stderr)
            return 1
    if args.cmd == "telemetry-compare":
        try:
            raw_actual = _load_telemetry_input(args.actual, args.format)
            raw_target = _load_telemetry_input(args.target, args.format)
            actual_rows, actual_summary = _annotate_telemetry_rows(
                rows=raw_actual,
                step_sec=max(0.001, args.step_sec),
                maxq_start_sec=args.phase_maxq_start_sec,
                maxq_end_sec=args.phase_maxq_end_sec,
                meco_sec=args.phase_meco_sec,
                seco_sec=args.phase_seco_sec,
            )
            target_rows, target_summary = _annotate_telemetry_rows(
                rows=raw_target,
                step_sec=max(0.001, args.step_sec),
                maxq_start_sec=args.phase_maxq_start_sec,
                maxq_end_sec=args.phase_maxq_end_sec,
                meco_sec=args.phase_meco_sec,
                seco_sec=args.phase_seco_sec,
            )
            report = _compare_telemetry(
                actual_rows=actual_rows,
                target_rows=target_rows,
                actual_summary=actual_summary,
                target_summary=target_summary,
            )
            print(json.dumps(report, indent=2))
            return 0
        except Exception as exc:  # noqa: BLE001
            print(f"error: {exc}", file=sys.stderr)
            return 1
    if args.cmd == "chunk":
        try:
            registry = _load_chunk_registry()
            if args.chunk_cmd == "list":
                if args.json:
                    print(json.dumps(registry, indent=2))
                    return 0
                chunk_rows = []
                for item in registry.get("chunks", []):
                    if isinstance(item, dict):
                        chunk_rows.append(
                            {
                                "id": item.get("id"),
                                "title": item.get("title"),
                                "version": item.get("version"),
                                "status": item.get("status", "active"),
                            }
                        )
                print(json.dumps({"chunks": chunk_rows, "count": len(chunk_rows)}, indent=2))
                return 0

            if args.chunk_cmd == "show":
                item = _find_chunk(args.id, registry)
                if not item:
                    raise ValueError(f"chunk id not found: {args.id}")
                print(json.dumps(item, indent=2))
                return 0

            if args.chunk_cmd == "run":
                result = _run_chunk_by_id(args.id, args)
                print(json.dumps(result, indent=2))
                if args.id == "telemetry.alert" and result.get("status") == "FAIL":
                    return 2
                return 0

            if args.chunk_cmd == "scaffold":
                out_dir = Path(__file__).parent / "chunks" / "custom"
                out_dir.mkdir(parents=True, exist_ok=True)
                out_path = out_dir / _safe_chunk_filename(args.id)
                if out_path.exists():
                    raise ValueError(f"chunk scaffold already exists: {out_path}")
                template = {
                    "id": args.id,
                    "title": args.title,
                    "version": "0.1.0",
                    "type": args.type,
                    "status": "draft",
                    "entrypoint": "chunk.run",
                    "inputs": [],
                    "outputs": [],
                    "notes": "Fill in runtime contract and wire handler in freya.",
                }
                with open(out_path, "w", encoding="utf-8") as fp:
                    json.dump(template, fp, indent=2)
                print(json.dumps({"status": "created", "path": str(out_path), "chunk": template}, indent=2))
                return 0
        except Exception as exc:  # noqa: BLE001
            print(f"error: {exc}", file=sys.stderr)
            return 1
    if args.cmd == "quantum":
        if args.quantum_cmd == "run":
            try:
                print(
                    json.dumps(
                        _run_quantum_program(
                            qubits=args.qubits,
                            program=args.program,
                            shots=max(0, args.shots),
                        ),
                        indent=2,
                    )
                )
                return 0
            except Exception as exc:  # noqa: BLE001
                print(f"error: {exc}", file=sys.stderr)
                return 1

    return 1


