def _enterprise_ops_report(window_hours: int = 24) -> dict:
    _ensure_state_dir()
    cutoff = datetime.now(tz=timezone.utc).timestamp() - (max(1, window_hours) * 3600)
    audit_rows = []
    if FREYA_AUDIT_LOG_PATH.exists():
        with open(FREYA_AUDIT_LOG_PATH, encoding="utf-8") as fp:
            for line in fp:
                line = line.strip()
                if not line:
                    continue
                try:
                    obj = json.loads(line)
                except Exception:  # noqa: BLE001
                    continue
                ts = obj.get("t", "")
                try:
                    epoch = datetime.fromisoformat(str(ts).replace("Z", "+00:00")).timestamp()
                except Exception:  # noqa: BLE001
                    epoch = 0.0
                if epoch >= cutoff:
                    audit_rows.append(obj)
    pass_count = sum(1 for r in audit_rows if str(r.get("status", "")).upper() in {"PASS", "OK", "SUCCESS"})
    total = len(audit_rows)
    error_rate = 0.0 if total == 0 else (1.0 - (pass_count / total))
    artifacts = _artifact_list().get("count", 0)
    sessions = len(list(FREYA_SESSION_DIR.glob("*.json"))) if FREYA_SESSION_DIR.exists() else 0
    return {
        "windowHours": window_hours,
        "auditEvents": total,
        "passEvents": pass_count,
        "errorRate": error_rate,
        "sloTargetErrorRate": 0.001,
        "sloPass": error_rate <= 0.001,
        "artifactCount": artifacts,
        "sessionCount": sessions,
    }


def _market_convert(amount: float, base: str, quote: str) -> dict:
    base_u = base.upper()
    quote_u = quote.upper()
    crypto = {"BTC", "ETH", "SOL", "USDT", "USDC"}
    fiat_fallback_usd = {
        "USD": 1.0,
        "EUR": 0.93,
        "GBP": 0.79,
        "JPY": 149.0,
        "CAD": 1.36,
        "AUD": 1.52,
        "CHF": 0.89,
    }
    crypto_fallback_usd = {"BTC": 65000.0, "ETH": 3200.0, "SOL": 145.0, "USDT": 1.0, "USDC": 1.0}

    # Fiat lane via Frankfurter.
    if base_u not in crypto and quote_u not in crypto:
        try:
            q = urllib.parse.urlencode({"amount": amount, "from": base_u, "to": quote_u})
            data = _get_json(f"https://api.frankfurter.app/latest?{q}")
            rate = float(data["rates"][quote_u]) / max(1e-12, amount)
            converted = float(data["rates"][quote_u])
            return {
                "kind": "fiat",
                "base": base_u,
                "quote": quote_u,
                "amount": amount,
                "rate": rate,
                "converted": converted,
                "source": "frankfurter",
            }
        except Exception:  # noqa: BLE001
            b = fiat_fallback_usd.get(base_u)
            qv = fiat_fallback_usd.get(quote_u)
            if b is None or qv is None:
                raise ValueError(f"unsupported fiat pair fallback: {base_u}/{quote_u}")
            usd = amount / b
            converted = usd * qv
            return {
                "kind": "fiat",
                "base": base_u,
                "quote": quote_u,
                "amount": amount,
                "rate": converted / max(1e-12, amount),
                "converted": converted,
                "source": "fallback-table",
            }

    # Crypto lane via CoinGecko.
    try:
        symbol_to_id = {"BTC": "bitcoin", "ETH": "ethereum", "SOL": "solana", "USDT": "tether", "USDC": "usd-coin"}
        ids = []
        if base_u in symbol_to_id:
            ids.append(symbol_to_id[base_u])
        if quote_u in symbol_to_id:
            ids.append(symbol_to_id[quote_u])
        qv = "usd" if quote_u in crypto else quote_u.lower()
        params = urllib.parse.urlencode({"ids": ",".join(sorted(set(ids))), "vs_currencies": qv if quote_u in crypto else f"usd,{quote_u.lower()}"})
        data = _get_json(f"https://api.coingecko.com/api/v3/simple/price?{params}")
        if base_u in crypto and quote_u in crypto:
            b_usd = float(data[symbol_to_id[base_u]]["usd"])
            q_usd = float(data[symbol_to_id[quote_u]]["usd"])
            rate = b_usd / max(1e-12, q_usd)
            converted = amount * rate
        elif base_u in crypto:
            b_usd = float(data[symbol_to_id[base_u]]["usd"])
            if quote_u == "USD":
                rate = b_usd
            else:
                fx = _market_convert(1.0, "USD", quote_u)
                rate = b_usd * float(fx["converted"])
            converted = amount * rate
        else:
            # fiat -> crypto
            q_id = symbol_to_id[quote_u]
            q_usd = float(data[q_id]["usd"])
            usd_amount = amount if base_u == "USD" else float(_market_convert(amount, base_u, "USD")["converted"])
            converted = usd_amount / max(1e-12, q_usd)
            rate = converted / max(1e-12, amount)
        return {
            "kind": "crypto",
            "base": base_u,
            "quote": quote_u,
            "amount": amount,
            "rate": rate,
            "converted": converted,
            "source": "coingecko+fx",
        }
    except Exception:  # noqa: BLE001
        def usd_price(sym: str) -> float:
            if sym in crypto:
                return crypto_fallback_usd[sym]
            if sym in fiat_fallback_usd:
                return 1.0 / fiat_fallback_usd[sym]
            raise ValueError(f"unsupported symbol for fallback: {sym}")
        b_usd = usd_price(base_u)
        q_usd = usd_price(quote_u)
        rate = b_usd / max(1e-12, q_usd)
        return {
            "kind": "crypto",
            "base": base_u,
            "quote": quote_u,
            "amount": amount,
            "rate": rate,
            "converted": amount * rate,
            "source": "fallback-table",
        }


def _market_quote(symbol: str, market: str) -> dict:
    sym = symbol.strip().upper()
    mk = market.strip().lower()
    if mk == "stock":
        try:
            stooq_symbol = sym.lower() if "." in sym else f"{sym.lower()}.us"
            raw = _get_text(f"https://stooq.com/q/l/?s={stooq_symbol}&i=d")
            lines = [ln.strip() for ln in raw.splitlines() if ln.strip()]
            if len(lines) >= 2:
                # Symbol,Date,Time,Open,High,Low,Close,Volume
                cols = [c.strip() for c in lines[1].split(",")]
                return {
                    "market": "stock",
                    "symbol": sym,
                    "price": float(cols[6]),
                    "open": float(cols[3]),
                    "high": float(cols[4]),
                    "low": float(cols[5]),
                    "volume": cols[7],
                    "source": "stooq",
                }
        except Exception:  # noqa: BLE001
            pass
        fallback = {"AAPL": 210.0, "MSFT": 420.0, "NVDA": 900.0, "TSLA": 190.0}
        if sym not in fallback:
            raise ValueError(f"unsupported stock fallback symbol: {sym}")
        return {"market": "stock", "symbol": sym, "price": fallback[sym], "source": "fallback-table"}

    # crypto quote
    symbol_to_id = {"BTC": "bitcoin", "ETH": "ethereum", "SOL": "solana", "USDT": "tether", "USDC": "usd-coin"}
    if sym not in symbol_to_id:
        raise ValueError(f"unsupported crypto symbol: {sym}")
    try:
        data = _get_json(
            "https://api.coingecko.com/api/v3/simple/price?"
            + urllib.parse.urlencode({"ids": symbol_to_id[sym], "vs_currencies": "usd"})
        )
        return {"market": "crypto", "symbol": sym, "priceUsd": float(data[symbol_to_id[sym]]["usd"]), "source": "coingecko"}
    except Exception:  # noqa: BLE001
        fallback = {"BTC": 65000.0, "ETH": 3200.0, "SOL": 145.0, "USDT": 1.0, "USDC": 1.0}
        return {"market": "crypto", "symbol": sym, "priceUsd": fallback[sym], "source": "fallback-table"}


def _code_qr_payload(text: str, size: int) -> dict:
    clean = text.strip()
    if not clean:
        raise ValueError("qr text must not be empty")
    px = max(96, min(2048, int(size)))
    encoded = urllib.parse.quote(clean, safe="")
    png_url = f"https://api.qrserver.com/v1/create-qr-code/?size={px}x{px}&data={encoded}"
    svg_url = f"https://api.qrserver.com/v1/create-qr-code/?size={px}x{px}&format=svg&data={encoded}"
    return {"text": clean, "size": px, "pngUrl": png_url, "svgUrl": svg_url}


def _code_qr(text: str, size: int, out: str | None) -> dict:
    payload = _code_qr_payload(text, size)
    if out:
        out_path = Path(out)
        out_path.parent.mkdir(parents=True, exist_ok=True)
        req = urllib.request.Request(payload["pngUrl"], method="GET")
        with urllib.request.urlopen(req, timeout=30) as resp:
            out_path.write_bytes(resp.read())
        payload["saved"] = str(out_path)
    return payload


def _code_lookup(code: str) -> dict:
    c = "".join(ch for ch in code.strip() if ch.isdigit() or ch.upper() == "X")
    if not c:
        raise ValueError("code must not be empty")

    # 1) OpenLibrary ISBN (books)
    if len(c) in {10, 13}:
        try:
            data = _get_json(f"https://openlibrary.org/isbn/{c}.json")
            return {
                "code": c,
                "type": "isbn",
                "source": "openlibrary",
                "title": data.get("title"),
                "publishDate": data.get("publish_date"),
                "publishers": data.get("publishers", []),
                "authors": data.get("authors", []),
                "raw": data,
            }
        except Exception:  # noqa: BLE001
            pass

    # 2) Google Books fallback
    if len(c) in {10, 13}:
        try:
            q = urllib.parse.quote(f"isbn:{c}", safe="")
            data = _get_json(f"https://www.googleapis.com/books/v1/volumes?q={q}")
            items = data.get("items", [])
            if items:
                vi = items[0].get("volumeInfo", {})
                return {
                    "code": c,
                    "type": "isbn",
                    "source": "google-books",
                    "title": vi.get("title"),
                    "authors": vi.get("authors", []),
                    "publisher": vi.get("publisher"),
                    "publishedDate": vi.get("publishedDate"),
                    "categories": vi.get("categories", []),
                    "raw": vi,
                }
        except Exception:  # noqa: BLE001
            pass

    # 3) OpenFoodFacts for UPC/EAN products
    try:
        data = _get_json(f"https://world.openfoodfacts.org/api/v2/product/{c}.json")
        prod = data.get("product", {})
        if prod:
            return {
                "code": c,
                "type": "barcode",
                "source": "openfoodfacts",
                "name": prod.get("product_name") or prod.get("generic_name"),
                "brand": prod.get("brands"),
                "quantity": prod.get("quantity"),
                "categories": prod.get("categories"),
                "raw": prod,
            }
    except Exception:  # noqa: BLE001
        pass

    return {
        "code": c,
        "type": "unknown",
        "source": "none",
        "message": "No match found in OpenLibrary, Google Books, or OpenFoodFacts.",
    }


def _code_quicklist(codes: str) -> dict:
    tokens = [
        "".join(ch for ch in raw.strip() if ch.isdigit() or ch.upper() == "X")
        for raw in codes.replace("\n", ",").split(",")
    ]
    clean_codes = [t for t in tokens if t]
    if not clean_codes:
        raise ValueError("codes list is empty")
    items = []
    for c in clean_codes[:120]:
        hit = _code_lookup(c)
        label = hit.get("name") or hit.get("title") or f"item-{c}"
        items.append({"code": c, "label": label, "source": hit.get("source", "none"), "type": hit.get("type", "unknown")})
    return {
        "count": len(items),
        "items": items,
        "quickListText": "\n".join(
            f"{i + 1}. {it['label']} [{it['code']}] ({it['source']})" for i, it in enumerate(items)
        ),
    }


def _code_dam_tree(root: str, input_json: str | None) -> dict:
    root_clean = root.strip() or "kbatch/ingredients"
    items = []
    if input_json:
        path = Path(input_json)
        if not path.exists():
            raise FileNotFoundError(f"input json not found: {path}")
        raw = json.loads(path.read_text(encoding="utf-8"))
        if isinstance(raw, list):
            items = [x for x in raw if isinstance(x, dict)]
    groups: dict[str, list[dict]] = {}
    for it in items:
        g = str(it.get("unit", "unit"))
        groups.setdefault(g, []).append(it)
    total_qty = sum(float(it.get("qty", 0) or 0) for it in items)
    total_cost = sum((float(it.get("qty", 0) or 0) * float(it.get("cost", 0) or 0)) for it in items)
    reorder_cost = 0.0
    for it in items:
        par = float(it.get("par", 0) or 0)
        on_hand = float(it.get("onHand", 0) or 0)
        cost = float(it.get("cost", 0) or 0)
        reorder_cost += max(0.0, par - on_hand) * cost
    lane_scale = math.log10(max(1.0, total_qty + len(items)))
    group_lines = []
    for key, sub_items in groups.items():
        g_qty = sum(float(it.get("qty", 0) or 0) for it in sub_items)
        g_cost = sum((float(it.get("qty", 0) or 0) * float(it.get("cost", 0) or 0)) for it in sub_items)
        group_lines.append(f"├─ {key} ({len(sub_items)} items | qty={g_qty:.2f} | cost=${g_cost:.2f})")
    return {
        "root": root_clean,
        "codecFamily": [".q", ".qbit", ".steno.map"],
        "metrics": {
            "items": len(items),
            "totalQty": total_qty,
            "totalCost": total_cost,
            "reorderCost": reorder_cost,
            "laneScaleLog10": lane_scale,
            "qbitScaleScore": lane_scale * (1.0 + (len(items) / 10.0)),
        },
        "groups": {k: len(v) for k, v in groups.items()},
        "treeText": "\n".join(
            [
                root_clean,
                *group_lines,
            ]
        )
        if group_lines
        else root_clean,
    }


