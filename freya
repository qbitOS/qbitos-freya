def _build_quantum_preset_program(preset: str, qubits: int, marked_state: str) -> str:
    p = preset.lower().strip()
    if p == "bell":
        if qubits != 2:
            raise ValueError("bell preset requires --qubits 2")
        return "h 0; cx 0 1; measure"
    if p == "ghz":
        if qubits < 2:
            raise ValueError("ghz preset requires --qubits >= 2")
        ops = ["h 0"]
        for i in range(qubits - 1):
            ops.append(f"cx {i} {i+1}")
        ops.append("measure")
        return "; ".join(ops)
    if p == "grover2":
        if qubits != 2:
            raise ValueError("grover2 preset requires --qubits 2")
        if marked_state != "11":
            raise ValueError("grover2 currently supports only --marked-state 11")
        # 2-qubit Grover: oracle(|11>) then diffuser.
        return "; ".join(
            [
                "h 0",
                "h 1",
                "h 1",
                "cx 0 1",
                "h 1",
                "h 0",
                "h 1",
                "x 0",
                "x 1",
                "h 1",
                "cx 0 1",
                "h 1",
                "x 0",
                "x 1",
                "h 0",
                "h 1",
                "measure",
            ]
        )
    raise ValueError(f"unsupported preset '{preset}'")


def _chunk_quantum_preset(args: argparse.Namespace) -> dict:
    program = _build_quantum_preset_program(args.preset, args.qubits, args.marked_state)
    return {
        "chunk": "quantum.preset",
        "preset": args.preset,
        "program": program,
        "result": _run_quantum_program(args.qubits, program, max(0, args.shots)),
    }


