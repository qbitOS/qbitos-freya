def _post_json(url: str, payload: dict, headers: dict | None = None, timeout: int = 45) -> dict:
    body = json.dumps(payload).encode("utf-8")
    req_headers = {"Content-Type": "application/json"}
    if headers:
        req_headers.update(headers)
    req = urllib.request.Request(url, data=body, headers=req_headers, method="POST")
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        raw = resp.read().decode("utf-8")
        return json.loads(raw) if raw else {}


def _get_json(url: str, headers: dict | None = None, timeout: int = 30) -> dict:
    req_headers = {}
    if headers:
        req_headers.update(headers)
    req = urllib.request.Request(url, headers=req_headers, method="GET")
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        raw = resp.read().decode("utf-8")
        return json.loads(raw) if raw else {}


def _get_text(url: str, headers: dict | None = None, timeout: int = 30) -> str:
    req_headers = {}
    if headers:
        req_headers.update(headers)
    req = urllib.request.Request(url, headers=req_headers, method="GET")
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        return resp.read().decode("utf-8")


def _erika_headers(require_key: bool = False) -> dict:
    headers = {"Content-Type": "application/json"}
    if ERIKA_API_KEY:
        headers["X-API-Key"] = ERIKA_API_KEY
    if require_key and "X-API-Key" not in headers:
        raise ValueError("missing API key: set FREYA_ERIKA_API_KEY (or CODEX_API_KEY)")
    return headers


def _erika_get(path: str, require_key: bool = False) -> dict:
    return _get_json(f"{ERIKA_BASE}{path}", headers=_erika_headers(require_key=require_key), timeout=45)


def _erika_post(path: str, payload: dict, require_key: bool = False) -> dict:
    return _post_json(f"{ERIKA_BASE}{path}", payload, headers=_erika_headers(require_key=require_key), timeout=60)


