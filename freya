                key = os.getenv("UGRAD_MODELLAB_API_KEY", os.getenv("LOCAL_LLM_API_KEY", "local"))
                if not base:
                    raise RuntimeError("UGRAD_MODELLAB_BASE_URL is not set")
                out[bk] = {"status": "ok", "models": _list_openai_compat_models(base, key)}
            elif bk == "huggingface":
                out[bk] = {
                    "status": "ok",
                    "models": list(FAMILY_MODEL_MAP["huggingface"].values()),
                    "note": "Catalog is much larger; this lists directly supported family defaults.",
                }
            elif bk == "mistral":
                out[bk] = {
                    "status": "ok",
                    "models": [os.getenv("MISTRAL_MODEL", "mistral-small-latest")],
                    "note": "Set MISTRAL_MODEL to change default.",
                }
            else:
                out[bk] = {"status": "error", "error": "unknown backend"}
        except Exception as exc:  # noqa: BLE001
            out[bk] = {"status": "error", "error": str(exc)}
    return out


def _chat_openai_compat(query: str, base_url: str, model: str, api_key: str | None) -> str:
    url = base_url.rstrip("/") + "/chat/completions"
    headers = {"Authorization": f"Bearer {api_key or 'local'}"}
    payload = {
        "model": model,
        "messages": [{"role": "user", "content": query}],
        "temperature": 0.2,
    }
    data = _post_json(url, payload, headers=headers)
    try:
        return data["choices"][0]["message"]["content"]
    except Exception as exc:  # noqa: BLE001
        raise RuntimeError(f"OpenAI-compatible parse failed: {exc}; response={data}") from exc


def _chat_ollama(query: str, base_url: str, model: str) -> str:
    url = base_url.rstrip("/") + "/api/chat"
    payload = {
        "model": model,
        "messages": [{"role": "user", "content": query}],
        "stream": False,
    }
    data = _post_json(url, payload)
    try:
        return data["message"]["content"]
    except Exception as exc:  # noqa: BLE001
        raise RuntimeError(f"Ollama parse failed: {exc}; response={data}") from exc


def _chat_huggingface(query: str, model: str, token: str) -> str:
    url = f"https://api-inference.huggingface.co/models/{model}"
    payload = {"inputs": query}
    headers = {"Authorization": f"Bearer {token}"}
    data = _post_json(url, payload, headers=headers)
    if isinstance(data, dict) and data.get("error"):
        raise RuntimeError(f"Hugging Face API error: {data['error']}")
    if isinstance(data, list) and data:
        item = data[0]
        if isinstance(item, dict):
            if "generated_text" in item:
                return str(item["generated_text"])
            if "summary_text" in item:
                return str(item["summary_text"])
    return str(data)


def _chat_mistral_sdk(query: str, model: str) -> str:
    try:
        from mistralai import client
        from mistralai.client.models import UserMessage
    except ImportError as exc:
        raise RuntimeError(f"ImportError: {exc}. Install Mistral SDK with: pip install mistralai") from exc

    mistral_client = client.Mistral()
    chat_response = mistral_client.chat.complete(
        model=model,
        messages=[UserMessage(content=query)],
    )
    try:
        return chat_response.choices[0].message.content
    except Exception as exc:  # noqa: BLE001
        raise RuntimeError(f"Mistral response parse failed: {exc}") from exc


def chat_conversion(query: str, backend: str, model: str | None = None, family: str | None = None) -> str:
    """Route chat query across local and hosted backends."""
    auto_chain = []
    if backend == "auto":
        auto_chain = ["lmstudio", "ollama", "ugrad", "huggingface", "mistral"]
    else:
        auto_chain = [backend]

    last_error = None
    for bk in auto_chain:
        try:
            if bk == "lmstudio":
                base_url = os.getenv("LOCAL_LLM_BASE_URL", "http://127.0.0.1:1234/v1")
                mdl = _resolve_model("lmstudio", model, family)
                key = os.getenv("LOCAL_LLM_API_KEY", "lm-studio")
                return _chat_openai_compat(query, base_url, mdl, key)
            if bk == "ollama":
                base_url = os.getenv("OLLAMA_BASE_URL", "http://127.0.0.1:11434")
                mdl = _resolve_model("ollama", model, family)
                return _chat_ollama(query, base_url, mdl)
            if bk == "ugrad":
                base_url = os.getenv("UGRAD_MODELLAB_BASE_URL", "").strip()
                if not base_url:
                    raise RuntimeError("UGRAD_MODELLAB_BASE_URL is not set")
                mdl = _resolve_model("ugrad", model, family)
                key = os.getenv("UGRAD_MODELLAB_API_KEY", os.getenv("LOCAL_LLM_API_KEY", "local"))
                return _chat_openai_compat(query, base_url, mdl, key)
            if bk == "huggingface":
                token = os.getenv("HF_API_TOKEN", "")
                mdl = _resolve_model("huggingface", model, family)
                if not token:
                    raise RuntimeError("HF_API_TOKEN is not set")
                return _chat_huggingface(query, mdl, token)
            if bk == "mistral":
                mdl = _resolve_model("mistral", model, family)
                if not os.getenv("MISTRAL_API_KEY"):
                    raise RuntimeError("MISTRAL_API_KEY is not set")
                return _chat_mistral_sdk(query, mdl)
            raise RuntimeError(f"Unknown backend '{bk}'")
        except urllib.error.URLError as exc:
            last_error = f"{bk}: connection failed ({exc})"
        except Exception as exc:  # noqa: BLE001
            last_error = f"{bk}: {exc}"
            if backend != "auto":
                break

    return f"Error: {last_error}" if last_error else "Error: no backend attempted"


def _gravity(altitude_m: float) -> float:
    earth_radius_m = 6_371_000.0
    g0 = 9.80665
    return g0 * (earth_radius_m / (earth_radius_m + max(0.0, altitude_m))) ** 2


def _air_density(altitude_m: float) -> float:
    # Simple exponential model, good enough for fast onboard estimates.
    return 1.225 * math.exp(-max(0.0, altitude_m) / 8500.0)


def _to_float(value: object, default: float = 0.0) -> float:
    try:
        if value is None:
            return default
        return float(value)
    except (TypeError, ValueError):
        return default


def _extract_time_sec(raw: dict) -> float:
    # Accept a broad set of timestamp keys for compatibility across telemetry producers.
    if "tSec" in raw:
        return _to_float(raw.get("tSec"), 0.0)
    if "timeSec" in raw:
        return _to_float(raw.get("timeSec"), 0.0)
    if "time" in raw:
        return _to_float(raw.get("time"), 0.0)
    if "timestampSec" in raw:
        return _to_float(raw.get("timestampSec"), 0.0)
    if "timestampMs" in raw:
        return _to_float(raw.get("timestampMs"), 0.0) / 1000.0
    if "timestamp" in raw:
        ts = _to_float(raw.get("timestamp"), 0.0)
        # Heuristic: values larger than year-2001 epoch-ms threshold are likely milliseconds.
        return ts / 1000.0 if ts > 1_000_000_000_000 else ts
    return 0.0


def _parse_smpte_to_seconds(smpte: str, fps: float) -> float:
    parts = [p.strip() for p in smpte.strip().split(":")]
    if len(parts) != 4:
        raise ValueError("smpte must be HH:MM:SS:FF")
    hh, mm, ss, ff = [int(x) for x in parts]
    if mm < 0 or mm > 59 or ss < 0 or ss > 59:
        raise ValueError("smpte MM/SS must be in 0..59")
    if ff < 0 or ff >= int(max(1.0, fps) + 1):
        raise ValueError("smpte FF out of range for fps")
    return (hh * 3600.0) + (mm * 60.0) + ss + (ff / max(1.0, fps))


def _format_seconds_to_smpte(seconds: float, fps: float) -> str:
    sec = max(0.0, float(seconds))
    base = int(sec)
    frac = sec - base
    hh = base // 3600
    mm = (base % 3600) // 60
    ss = base % 60
    ff = int(round(frac * max(1.0, fps)))
    if ff >= int(max(1.0, fps)):
        ff = 0
        ss += 1
        if ss >= 60:
            ss = 0
            mm += 1
            if mm >= 60:
                mm = 0
                hh += 1
    return f"{hh:02d}:{mm:02d}:{ss:02d}:{ff:02d}"


def _time_convert(seconds: float | None, unix_ts: float | None, smpte: str | None, fps: float) -> dict:
    if seconds is None and unix_ts is None and not smpte:
        raise ValueError("provide one of --seconds, --unix, or --smpte")
    if smpte:
        sec = _parse_smpte_to_seconds(smpte, fps)
    elif seconds is not None:
        sec = float(seconds)
    else:
        sec = float(unix_ts)
    unix_out = float(unix_ts) if unix_ts is not None else sec
    iso = datetime.fromtimestamp(unix_out, tz=timezone.utc).isoformat()
    return {
        "input": {"seconds": seconds, "unix": unix_ts, "smpte": smpte, "fps": fps},
        "seconds": sec,
        "unix": unix_out,
        "isoUtc": iso,
        "smpte": _format_seconds_to_smpte(sec, fps),
    }


def _time_synclock(
    reference_unix: float,
    device_unix: float,
    reference_end_unix: float | None,
    device_end_unix: float | None,
    max_drift_ppm: float,
) -> dict:
    offset_sec = float(device_unix) - float(reference_unix)
    drift_ppm = 0.0
    if reference_end_unix is not None and device_end_unix is not None:
        ref_span = float(reference_end_unix) - float(reference_unix)
        dev_span = float(device_end_unix) - float(device_unix)
        if abs(ref_span) > 1e-9:
            drift_ppm = ((dev_span - ref_span) / ref_span) * 1_000_000.0
    status = "PASS" if abs(drift_ppm) <= max_drift_ppm else "WARN"
    return {
        "referenceUnix": reference_unix,
        "deviceUnix": device_unix,
        "offsetSec": offset_sec,
        "offsetMs": offset_sec * 1000.0,
        "driftPpm": drift_ppm,
        "maxDriftPpm": max_drift_ppm,
        "status": status,
        "syncRecommendation": "clock-locked" if status == "PASS" else "recalibrate clock source",
    }


def _time_calibrate(
    distance_m: float,
    duration_sec: float,
    mass_kg: float,
    power_w: float,
    clock_offset_ms: float,
    clock_drift_ppm: float,
) -> dict:
    if duration_sec <= 0:
        raise ValueError("duration_sec must be > 0")
    v_ms = distance_m / duration_sec
    v_kmh = v_ms * 3.6
    v_mph = v_ms * 2.2369362921
    kinetic_j = 0.5 * max(0.0, mass_kg) * v_ms * v_ms
    input_energy_j = max(0.0, power_w) * duration_sec
    eff = (kinetic_j / input_energy_j) if input_energy_j > 0 else 0.0
    sync_corr_sec = (clock_offset_ms / 1000.0) + (duration_sec * (clock_drift_ppm / 1_000_000.0))
    calibrated_duration = duration_sec - sync_corr_sec
    calibrated_speed_ms = distance_m / calibrated_duration if calibrated_duration > 0 else 0.0
    return {
        "distanceM": distance_m,
        "durationSec": duration_sec,
        "speedMs": v_ms,
        "speedKmh": v_kmh,
        "speedMph": v_mph,
        "massKg": mass_kg,
        "kineticEnergyJ": kinetic_j,
        "inputEnergyJ": input_energy_j,
        "efficiencyRatio": eff,
        "clock": {
            "offsetMs": clock_offset_ms,
            "driftPpm": clock_drift_ppm,
            "syncCorrectionSec": sync_corr_sec,
        },
        "calibratedDurationSec": calibrated_duration,
        "calibratedSpeedMs": calibrated_speed_ms,
    }


def _jawbreaker_speed_race(
    distance_m: float,
    laps: int,
    splits_csv: str,
    fps: float,
    reference_unix: float | None,
    device_unix: float | None,
) -> dict:
    splits = [float(x.strip()) for x in splits_csv.split(",") if x.strip()]
    if not splits:
        raise ValueError("splits must contain at least one lap time")
    laps_n = max(1, int(laps))
    total_sec = sum(splits)
    avg_lap = statistics.mean(splits)
    best_lap = min(splits)
    worst_lap = max(splits)
    distance_total = max(0.0, float(distance_m)) * laps_n
    avg_speed_ms = distance_total / total_sec if total_sec > 0 else 0.0
    sync = None
    if reference_unix is not None and device_unix is not None:
        sync = _time_synclock(reference_unix, device_unix, None, None, 50.0)
    return {
        "mode": "jawbreaker-speed-race",
        "laps": laps_n,
        "lapDistanceM": float(distance_m),
        "totalDistanceM": distance_total,
        "splitsSec": splits,
        "totalTimeSec": total_sec,
        "totalTimeSmpte": _format_seconds_to_smpte(total_sec, fps),
        "avgLapSec": avg_lap,
        "bestLapSec": best_lap,
        "worstLapSec": worst_lap,
        "avgSpeedMs": avg_speed_ms,
        "avgSpeedKmh": avg_speed_ms * 3.6,
        "avgSpeedMph": avg_speed_ms * 2.2369362921,
        "sync": sync,
    }


NOTE_INDEX = {"C": 0, "C#": 1, "DB": 1, "D": 2, "D#": 3, "EB": 3, "E": 4, "F": 5, "F#": 6, "GB": 6, "G": 7, "G#": 8, "AB": 8, "A": 9, "A#": 10, "BB": 10, "B": 11}
NOTE_SHARP = ["C", "C#", "D", "D#", "E", "F", "F#", "G", "G#", "A", "A#", "B"]


def _note_to_midi(note: str) -> int:
    s = note.strip().upper()
    if len(s) < 2:
        raise ValueError(f"invalid note '{note}'")
    head = s[0]
    accidental = ""
    octave_part = s[1:]
    if len(s) >= 3 and s[1] in {"#", "B"}:
        accidental = s[1]
        octave_part = s[2:]
    key = f"{head}{accidental}"
    if key not in NOTE_INDEX:
        raise ValueError(f"invalid note key '{note}'")
    octave = int(octave_part)
    midi = (octave + 1) * 12 + NOTE_INDEX[key]
    if midi < 0 or midi > 127:
        raise ValueError(f"midi note out of range for '{note}'")
    return midi


def _midi_to_note(midi: int) -> str:
    m = max(0, min(127, int(midi)))
    octave = (m // 12) - 1
    return f"{NOTE_SHARP[m % 12]}{octave}"


def _midi_to_freq(midi: int, a4_hz: float = 440.0) -> float:
    return float(a4_hz) * (2.0 ** ((int(midi) - 69) / 12.0))


def _music_transpose(notes: str, semitones: int, key: str) -> dict:
    src = [n.strip() for n in notes.replace("\n", ",").split(",") if n.strip()]
    if not src:
        raise ValueError("notes list is empty")
    out = []
    for n in src:
        m = _note_to_midi(n)
        mt = max(0, min(127, m + int(semitones)))
        out.append(
            {
                "input": n,
                "midi": m,
                "transposedMidi": mt,
                "transposed": _midi_to_note(mt),
                "freqHz": _midi_to_freq(m),
                "transposedFreqHz": _midi_to_freq(mt),
            }
        )
    return {
        "mode": "music.transpose",
        "key": key.strip() or "C",
        "semitones": int(semitones),
        "notesIn": src,
        "notesOut": [x["transposed"] for x in out],
        "mapping": out,
    }


def _music_binaural(base_hz: float, beat_hz: float, duration_sec: float) -> dict:
    base = max(1.0, float(base_hz))
    beat = max(0.01, float(beat_hz))
    left = base - (beat / 2.0)
    right = base + (beat / 2.0)
    return {
        "mode": "music.binaural",
        "baseHz": base,
        "beatHz": beat,
        "leftHz": left,
        "rightHz": right,
        "durationSec": max(0.0, float(duration_sec)),
        "signalFlow": f"oscL({left:.3f}Hz) -> panL, oscR({right:.3f}Hz) -> panR, binauralBeat={beat:.3f}Hz",
    }


def _music_daw_sync(
    bpm: float,
    sample_rate: int,
    buffer_size: int,
    ppq: int,
    bars: int,
    start_unix: float | None,
    fps: float,
) -> dict:
    bpm_v = max(1e-6, float(bpm))
    sr = max(1, int(sample_rate))
    buf = max(1, int(buffer_size))
    ppq_v = max(1, int(ppq))
    bars_v = max(1, int(bars))
    beat_sec = 60.0 / bpm_v
    bar_sec = beat_sec * 4.0
    total_sec = bar_sec * bars_v
    samples_per_beat = beat_sec * sr
    buffers_per_beat = samples_per_beat / buf
    ticks_per_sec = (bpm_v * ppq_v) / 60.0
    started = float(start_unix) if start_unix is not None else float(time.time())
    return {
        "mode": "music.daw-sync",
        "bpm": bpm_v,
        "sampleRate": sr,
        "bufferSize": buf,
        "ppq": ppq_v,
        "bars": bars_v,
        "beatSec": beat_sec,
        "barSec": bar_sec,
        "totalSec": total_sec,
        "samplesPerBeat": samples_per_beat,
        "buffersPerBeat": buffers_per_beat,
        "ticksPerSec": ticks_per_sec,
        "startUnix": started,
        "startSmpte": _format_seconds_to_smpte(started, fps),
    }


def _phase_for_time(
    t_sec: float,
    maxq_start_sec: float,
    maxq_end_sec: float,
    meco_sec: float | None,
    seco_sec: float | None,
) -> str:
    if t_sec < 0:
        return "PRELAUNCH"
    if meco_sec is not None and t_sec >= meco_sec:
        if seco_sec is not None and t_sec >= seco_sec:
            return "SECO_ORBIT_INSERT"
        return "COAST_POST_MECO"
    if maxq_start_sec <= t_sec <= maxq_end_sec:
        return "MAXQ_BUCKET"
    return "ASCENT_POWERED"


def _event_for_time(
    t_sec: float,
    step_sec: float,
    meco_sec: float | None,
    seco_sec: float | None,
) -> str | None:
    eps = max(0.001, step_sec / 2.0)
    if abs(t_sec - 0.0) <= eps:
        return "LIFTOFF"
    if meco_sec is not None and abs(t_sec - meco_sec) <= eps:
        return "MECO"
    if seco_sec is not None and abs(t_sec - seco_sec) <= eps:
        return "SECO"
    return None


def _load_telemetry_input(path: str, input_format: str) -> list[dict]:
    fmt = input_format.lower()
    if fmt == "auto":
        suffix = Path(path).suffix.lower()
        if suffix in {".csv"}:
            fmt = "csv"
        elif suffix in {".json"}:
            fmt = "json"
        elif suffix in {".jsonl", ".ndjson"}:
            fmt = "jsonl"
        else:
            fmt = "jsonl"

    rows: list[dict] = []
    if fmt == "csv":
        with open(path, encoding="utf-8", newline="") as fp:
            for row in csv.DictReader(fp):
                rows.append(dict(row))
    elif fmt == "json":
        with open(path, encoding="utf-8") as fp:
            data = json.load(fp)
        if isinstance(data, list):
            rows = [r for r in data if isinstance(r, dict)]
        elif isinstance(data, dict) and isinstance(data.get("rows"), list):
            rows = [r for r in data["rows"] if isinstance(r, dict)]
        else:
            raise ValueError("json input must be a list[object] or object with rows[]")
    elif fmt == "jsonl":
        with open(path, encoding="utf-8") as fp:
            for raw in fp:
                line = raw.strip()
                if not line:
                    continue
                obj = json.loads(line)
                if isinstance(obj, dict):
                    rows.append(obj)
    else:
        raise ValueError(f"unsupported input format '{fmt}'")

    if not rows:
        raise ValueError("telemetry ingest produced zero rows")
    return rows


def _annotate_telemetry_rows(
    rows: list[dict],
    step_sec: float,
    maxq_start_sec: float,
    maxq_end_sec: float,
    meco_sec: float | None,
    seco_sec: float | None,
) -> tuple[list[dict], dict]:
    normalized: list[dict] = []
    max_q_pa = -1.0
    max_q_t = 0.0
    max_accel_m_s2 = 0.0
    g0 = 9.80665

    for raw in rows:
        t_sec = _extract_time_sec(raw)
        alt_m = _to_float(raw.get("altitudeM"), _to_float(raw.get("altitude"), 0.0))
        vel_m_s = _to_float(raw.get("velocityMs"), _to_float(raw.get("velocity"), 0.0))
        mass_kg = _to_float(raw.get("massKg"), 0.0)
        fuel_kg = _to_float(raw.get("fuelKg"), 0.0)
        accel_m_s2 = _to_float(raw.get("accelMs2"), _to_float(raw.get("accel"), 0.0))
        thrust_n = _to_float(raw.get("thrustN"), 0.0)

        q_pa = _to_float(raw.get("dynamicPressurePa"), -1.0)
        if q_pa < 0:
            q_pa = 0.5 * _air_density(alt_m) * vel_m_s * vel_m_s
        mach = _to_float(raw.get("machApprox"), -1.0)
        if mach < 0:
            mach = vel_m_s / 340.0
        twr = _to_float(raw.get("twr"), -1.0)
        if twr < 0:
            twr = thrust_n / (mass_kg * _gravity(alt_m)) if mass_kg > 0 and thrust_n > 0 else 0.0
        thermal = _to_float(raw.get("thermalLoadProxy"), -1.0)
        if thermal < 0:
            thermal = q_pa * max(0.0, mach)

        phase = _phase_for_time(t_sec, maxq_start_sec, maxq_end_sec, meco_sec, seco_sec)
        event = _event_for_time(t_sec, step_sec, meco_sec, seco_sec)

        row = {
            "tSec": round(t_sec, 3),
            "altitudeM": alt_m,
            "velocityMs": vel_m_s,
            "massKg": mass_kg,
            "fuelKg": fuel_kg,
            "accelMs2": accel_m_s2,
            "dynamicPressurePa": q_pa,
            "machApprox": mach,
            "twr": twr,
            "thermalLoadProxy": thermal,
            "phase": phase,
        }
        if event:
            row["event"] = event
        normalized.append(row)

        if q_pa > max_q_pa:
            max_q_pa = q_pa
            max_q_t = t_sec
        if abs(accel_m_s2) > max_accel_m_s2:
            max_accel_m_s2 = abs(accel_m_s2)

    normalized.sort(key=lambda r: _to_float(r.get("tSec"), 0.0))
    final = normalized[-1]
    summary = {
        "durationSec": _to_float(final.get("tSec"), 0.0),
        "stepSec": step_sec,
        "maxQPa": max_q_pa if max_q_pa >= 0 else 0.0,
        "maxQkPa": (max_q_pa / 1000.0) if max_q_pa >= 0 else 0.0,
        "maxQTimeSec": max_q_t,
        "maxAccelMs2": max_accel_m_s2,
        "maxAccelG": max_accel_m_s2 / g0,
        "phaseConfig": {
            "maxqStartSec": maxq_start_sec,
            "maxqEndSec": maxq_end_sec,
            "mecoSec": meco_sec,
            "secoSec": seco_sec,
        },
        "controlEnvelope": "DAC/Prefix/Steno/Iron-Line/Preflight/search-history controls",
    }
    return normalized, summary


def _validate_telemetry(
    rows: list[dict],
    summary: dict,
    max_q_kpa: float,
    max_accel_g: float,
    min_twr: float,
    max_thermal: float,
) -> dict:
    violations: list[dict] = []
    for row in rows:
        t_sec = _to_float(row.get("tSec"), 0.0)
        q_kpa = _to_float(row.get("dynamicPressurePa"), 0.0) / 1000.0
        accel_g = abs(_to_float(row.get("accelMs2"), 0.0)) / 9.80665
        twr = _to_float(row.get("twr"), 0.0)
        thermal = _to_float(row.get("thermalLoadProxy"), 0.0)
        phase = str(row.get("phase", "UNKNOWN"))

        if q_kpa > max_q_kpa:
            violations.append({"tSec": t_sec, "metric": "maxQkPa", "value": q_kpa, "limit": max_q_kpa, "phase": phase})
        if accel_g > max_accel_g:
            violations.append({"tSec": t_sec, "metric": "maxAccelG", "value": accel_g, "limit": max_accel_g, "phase": phase})
        if phase in {"ASCENT_POWERED", "MAXQ_BUCKET"} and twr < min_twr:
            violations.append({"tSec": t_sec, "metric": "minTWR", "value": twr, "limit": min_twr, "phase": phase})
        if thermal > max_thermal:
            violations.append(
                {"tSec": t_sec, "metric": "maxThermalProxy", "value": thermal, "limit": max_thermal, "phase": phase}
            )

    status = "PASS" if not violations else "FAIL"
    return {
        "status": status,
        "thresholds": {
            "maxQkPa": max_q_kpa,
            "maxAccelG": max_accel_g,
            "minTwrPowered": min_twr,
            "maxThermalProxy": max_thermal,
        },
        "summary": summary,
        "violationCount": len(violations),
        "violations": violations[:50],
    }


def _rows_to_time_map(rows: list[dict]) -> dict[float, dict]:
    out: dict[float, dict] = {}
    for row in rows:
        t = round(_to_float(row.get("tSec"), 0.0), 3)
        out[t] = row
    return out


def _compare_telemetry(actual_rows: list[dict], target_rows: list[dict], actual_summary: dict, target_summary: dict) -> dict:
    a_map = _rows_to_time_map(actual_rows)
    t_map = _rows_to_time_map(target_rows)
    common_t = sorted(set(a_map.keys()) & set(t_map.keys()))
    if not common_t:
        raise ValueError("no overlapping tSec values between actual and target telemetry")

    sq_alt = 0.0
    sq_vel = 0.0
    max_abs_alt = 0.0
    max_abs_vel = 0.0
    drift_samples: list[dict] = []

    for t_sec in common_t:
        a = a_map[t_sec]
        b = t_map[t_sec]
        d_alt = _to_float(a.get("altitudeM")) - _to_float(b.get("altitudeM"))
        d_vel = _to_float(a.get("velocityMs")) - _to_float(b.get("velocityMs"))
        sq_alt += d_alt * d_alt
        sq_vel += d_vel * d_vel
        max_abs_alt = max(max_abs_alt, abs(d_alt))
        max_abs_vel = max(max_abs_vel, abs(d_vel))
        if len(drift_samples) < 8:
            drift_samples.append(
                {
                    "tSec": t_sec,
                    "deltaAltitudeM": d_alt,
                    "deltaVelocityMs": d_vel,
                }
            )

    n = float(len(common_t))
    rmse_alt = math.sqrt(sq_alt / n)
    rmse_vel = math.sqrt(sq_vel / n)

    a_max_q_kpa = _to_float(actual_summary.get("maxQkPa"), 0.0)
    t_max_q_kpa = _to_float(target_summary.get("maxQkPa"), 0.0)

    return {
        "samplesCompared": int(n),
        "timeRangeSec": {"start": common_t[0], "end": common_t[-1]},
        "rmseAltitudeM": rmse_alt,
        "rmseVelocityMs": rmse_vel,
        "maxAbsAltitudeDriftM": max_abs_alt,
        "maxAbsVelocityDriftMs": max_abs_vel,
        "maxQDeltaKPa": a_max_q_kpa - t_max_q_kpa,
        "actualMaxQkPa": a_max_q_kpa,
        "targetMaxQkPa": t_max_q_kpa,
        "driftSamples": drift_samples,
    }


