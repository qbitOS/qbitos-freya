def _safe_chunk_filename(chunk_id: str) -> str:
    allowed = []
    for ch in chunk_id.strip().lower():
        if ch.isalnum() or ch in {"-", "_", "."}:
            allowed.append(ch)
        else:
            allowed.append("-")
    name = "".join(allowed).strip(".-") or "chunk"
    return f"{name}.json"


