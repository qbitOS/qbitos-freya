def _chem_lookup(query: str) -> dict:
    q = query.strip()
    if not q:
        raise ValueError("query is empty")
    if q.isdigit():
        z = int(q)
        for e in CHEM_ELEMENTS:
            if int(e["z"]) == z:
                return e
        raise ValueError(f"element with atomic number {z} not found")
    q_u = q.upper()
    for e in CHEM_ELEMENTS:
        if str(e["sym"]).upper() == q_u:
            return e
    q_l = q.lower()
    for e in CHEM_ELEMENTS:
        if str(e["name"]).lower() == q_l:
            return e
    raise ValueError(f"element not found: {query}")


def _chemistry_periodic(query: str) -> dict:
    item = _chem_lookup(query)
    return {
        "mode": "chemistry.periodic",
        "query": query,
        "element": item,
        "metaResearchHint": "Use as seed for materials-science bond lattice exploration.",
    }


def _chemistry_bond(a: str, b: str) -> dict:
    ea = _chem_lookup(a)
    eb = _chem_lookup(b)
    delta = abs(float(ea.get("en", 0.0)) - float(eb.get("en", 0.0)))
    if delta > 1.7:
        bond_type = "ionic"
    elif delta > 0.4:
        bond_type = "polar-covalent"
    else:
        bond_type = "covalent"
    energy_proxy = round((delta + 0.5) * 180.0, 3)
    return {
        "mode": "chemistry.bond",
        "a": ea,
        "b": eb,
        "deltaEN": delta,
        "bondType": bond_type,
        "bondEnergyProxyKJMol": energy_proxy,
        "materialScienceHint": "meta-research inspired proxy for screening candidate compositions",
    }


def _geometry_eval(expr: str, x: float) -> float:
    env = {
        "__builtins__": {},
        "x": float(x),
        "pi": math.pi,
        "e": math.e,
        "sin": math.sin,
        "cos": math.cos,
        "tan": math.tan,
        "asin": math.asin,
        "acos": math.acos,
        "atan": math.atan,
        "sqrt": math.sqrt,
        "log": math.log,
        "exp": math.exp,
        "abs": abs,
        "pow": pow,
    }
    return float(eval(expr, env, {}))  # noqa: S307


def _geometry_plot(expr: str, x_min: float, x_max: float, steps: int) -> dict:
    if steps < 2:
        raise ValueError("steps must be >= 2")
    if x_max == x_min:
        raise ValueError("x_max must differ from x_min")
    dx = (x_max - x_min) / float(steps)
    points = []
    finite = []
    for i in range(steps + 1):
        x = x_min + (i * dx)
        try:
            y = _geometry_eval(expr, x)
        except Exception:  # noqa: BLE001
            y = float("nan")
        points.append({"x": x, "y": y})
        if math.isfinite(y):
            finite.append(y)
    return {
        "mode": "geometry.plot",
        "expr": expr,
        "xMin": x_min,
        "xMax": x_max,
        "steps": steps,
        "finiteCount": len(finite),
        "yMin": min(finite) if finite else None,
        "yMax": max(finite) if finite else None,
        "points": points,
    }


def _geometry_shape(shape: str, a: float, b: float, c: float) -> dict:
    s = shape.strip().lower()
    av = max(0.0, float(a))
    bv = max(0.0, float(b))
    cv = max(0.0, float(c))
    if s == "circle":
        return {"shape": s, "radius": av, "area": math.pi * av * av, "perimeter": 2.0 * math.pi * av}
    if s == "rectangle":
        return {"shape": s, "width": av, "height": bv, "area": av * bv, "perimeter": 2.0 * (av + bv)}
    if s == "triangle":
        sp = (av + bv + cv) / 2.0
        area = math.sqrt(max(0.0, sp * (sp - av) * (sp - bv) * (sp - cv)))
        return {"shape": s, "a": av, "b": bv, "c": cv, "perimeter": av + bv + cv, "area": area}
    if s == "sphere":
        return {"shape": s, "radius": av, "surface": 4.0 * math.pi * av * av, "volume": (4.0 / 3.0) * math.pi * av**3}
    if s == "cube":
        return {"shape": s, "side": av, "surface": 6.0 * av * av, "volume": av**3}
    if s == "cylinder":
        return {"shape": s, "radius": av, "height": bv, "surface": 2.0 * math.pi * av * (av + bv), "volume": math.pi * av * av * bv}
    raise ValueError(f"unsupported shape: {shape}")


def _phase_for_time(
    t_sec: float,
    maxq_start_sec: float,
    maxq_end_sec: float,
    meco_sec: float | None,
    seco_sec: float | None,
) -> str:
    if t_sec < 0:
        return "PRELAUNCH"
    if meco_sec is not None and t_sec >= meco_sec:
        if seco_sec is not None and t_sec >= seco_sec:
            return "SECO_ORBIT_INSERT"
        return "COAST_POST_MECO"
    if maxq_start_sec <= t_sec <= maxq_end_sec:
        return "MAXQ_BUCKET"
    return "ASCENT_POWERED"


def _event_for_time(
    t_sec: float,
    step_sec: float,
    meco_sec: float | None,
    seco_sec: float | None,
) -> str | None:
    eps = max(0.001, step_sec / 2.0)
    if abs(t_sec - 0.0) <= eps:
        return "LIFTOFF"
    if meco_sec is not None and abs(t_sec - meco_sec) <= eps:
        return "MECO"
    if seco_sec is not None and abs(t_sec - seco_sec) <= eps:
        return "SECO"
    return None


def _load_telemetry_input(path: str, input_format: str) -> list[dict]:
    fmt = input_format.lower()
    if fmt == "auto":
        suffix = Path(path).suffix.lower()
        if suffix in {".csv"}:
            fmt = "csv"
        elif suffix in {".json"}:
            fmt = "json"
        elif suffix in {".jsonl", ".ndjson"}:
            fmt = "jsonl"
        else:
            fmt = "jsonl"

    rows: list[dict] = []
    if fmt == "csv":
        with open(path, encoding="utf-8", newline="") as fp:
            for row in csv.DictReader(fp):
                rows.append(dict(row))
    elif fmt == "json":
        with open(path, encoding="utf-8") as fp:
            data = json.load(fp)
        if isinstance(data, list):
            rows = [r for r in data if isinstance(r, dict)]
        elif isinstance(data, dict) and isinstance(data.get("rows"), list):
            rows = [r for r in data["rows"] if isinstance(r, dict)]
        else:
            raise ValueError("json input must be a list[object] or object with rows[]")
    elif fmt == "jsonl":
        with open(path, encoding="utf-8") as fp:
            for raw in fp:
                line = raw.strip()
                if not line:
                    continue
                obj = json.loads(line)
                if isinstance(obj, dict):
                    rows.append(obj)
    else:
        raise ValueError(f"unsupported input format '{fmt}'")

    if not rows:
        raise ValueError("telemetry ingest produced zero rows")
    return rows


def _annotate_telemetry_rows(
    rows: list[dict],
    step_sec: float,
    maxq_start_sec: float,
    maxq_end_sec: float,
    meco_sec: float | None,
    seco_sec: float | None,
) -> tuple[list[dict], dict]:
    normalized: list[dict] = []
    max_q_pa = -1.0
    max_q_t = 0.0
    max_accel_m_s2 = 0.0
    g0 = 9.80665

    for raw in rows:
        t_sec = _extract_time_sec(raw)
        alt_m = _to_float(raw.get("altitudeM"), _to_float(raw.get("altitude"), 0.0))
        vel_m_s = _to_float(raw.get("velocityMs"), _to_float(raw.get("velocity"), 0.0))
        mass_kg = _to_float(raw.get("massKg"), 0.0)
        fuel_kg = _to_float(raw.get("fuelKg"), 0.0)
        accel_m_s2 = _to_float(raw.get("accelMs2"), _to_float(raw.get("accel"), 0.0))
        thrust_n = _to_float(raw.get("thrustN"), 0.0)

        q_pa = _to_float(raw.get("dynamicPressurePa"), -1.0)
        if q_pa < 0:
            q_pa = 0.5 * _air_density(alt_m) * vel_m_s * vel_m_s
        mach = _to_float(raw.get("machApprox"), -1.0)
        if mach < 0:
            mach = vel_m_s / 340.0
        twr = _to_float(raw.get("twr"), -1.0)
        if twr < 0:
            twr = thrust_n / (mass_kg * _gravity(alt_m)) if mass_kg > 0 and thrust_n > 0 else 0.0
        thermal = _to_float(raw.get("thermalLoadProxy"), -1.0)
        if thermal < 0:
            thermal = q_pa * max(0.0, mach)

        phase = _phase_for_time(t_sec, maxq_start_sec, maxq_end_sec, meco_sec, seco_sec)
        event = _event_for_time(t_sec, step_sec, meco_sec, seco_sec)

        row = {
            "tSec": round(t_sec, 3),
            "altitudeM": alt_m,
            "velocityMs": vel_m_s,
            "massKg": mass_kg,
            "fuelKg": fuel_kg,
            "accelMs2": accel_m_s2,
            "dynamicPressurePa": q_pa,
            "machApprox": mach,
            "twr": twr,
            "thermalLoadProxy": thermal,
            "phase": phase,
        }
        if event:
            row["event"] = event
        normalized.append(row)

        if q_pa > max_q_pa:
            max_q_pa = q_pa
            max_q_t = t_sec
        if abs(accel_m_s2) > max_accel_m_s2:
            max_accel_m_s2 = abs(accel_m_s2)

    normalized.sort(key=lambda r: _to_float(r.get("tSec"), 0.0))
    final = normalized[-1]
    summary = {
        "durationSec": _to_float(final.get("tSec"), 0.0),
        "stepSec": step_sec,
        "maxQPa": max_q_pa if max_q_pa >= 0 else 0.0,
        "maxQkPa": (max_q_pa / 1000.0) if max_q_pa >= 0 else 0.0,
        "maxQTimeSec": max_q_t,
        "maxAccelMs2": max_accel_m_s2,
        "maxAccelG": max_accel_m_s2 / g0,
        "phaseConfig": {
            "maxqStartSec": maxq_start_sec,
            "maxqEndSec": maxq_end_sec,
            "mecoSec": meco_sec,
            "secoSec": seco_sec,
        },
        "controlEnvelope": "DAC/Prefix/Steno/Iron-Line/Preflight/search-history controls",
    }
    return normalized, summary


def _validate_telemetry(
    rows: list[dict],
    summary: dict,
    max_q_kpa: float,
    max_accel_g: float,
    min_twr: float,
    max_thermal: float,
) -> dict:
    violations: list[dict] = []
    for row in rows:
        t_sec = _to_float(row.get("tSec"), 0.0)
        q_kpa = _to_float(row.get("dynamicPressurePa"), 0.0) / 1000.0
        accel_g = abs(_to_float(row.get("accelMs2"), 0.0)) / 9.80665
        twr = _to_float(row.get("twr"), 0.0)
        thermal = _to_float(row.get("thermalLoadProxy"), 0.0)
        phase = str(row.get("phase", "UNKNOWN"))

        if q_kpa > max_q_kpa:
            violations.append({"tSec": t_sec, "metric": "maxQkPa", "value": q_kpa, "limit": max_q_kpa, "phase": phase})
        if accel_g > max_accel_g:
            violations.append({"tSec": t_sec, "metric": "maxAccelG", "value": accel_g, "limit": max_accel_g, "phase": phase})
        if phase in {"ASCENT_POWERED", "MAXQ_BUCKET"} and twr < min_twr:
            violations.append({"tSec": t_sec, "metric": "minTWR", "value": twr, "limit": min_twr, "phase": phase})
        if thermal > max_thermal:
            violations.append(
                {"tSec": t_sec, "metric": "maxThermalProxy", "value": thermal, "limit": max_thermal, "phase": phase}
            )

    status = "PASS" if not violations else "FAIL"
    return {
        "status": status,
        "thresholds": {
            "maxQkPa": max_q_kpa,
            "maxAccelG": max_accel_g,
            "minTwrPowered": min_twr,
            "maxThermalProxy": max_thermal,
        },
        "summary": summary,
        "violationCount": len(violations),
        "violations": violations[:50],
    }


def _rows_to_time_map(rows: list[dict]) -> dict[float, dict]:
    out: dict[float, dict] = {}
    for row in rows:
        t = round(_to_float(row.get("tSec"), 0.0), 3)
        out[t] = row
    return out


def _compare_telemetry(actual_rows: list[dict], target_rows: list[dict], actual_summary: dict, target_summary: dict) -> dict:
    a_map = _rows_to_time_map(actual_rows)
    t_map = _rows_to_time_map(target_rows)
    common_t = sorted(set(a_map.keys()) & set(t_map.keys()))
    if not common_t:
        raise ValueError("no overlapping tSec values between actual and target telemetry")

    sq_alt = 0.0
    sq_vel = 0.0
    max_abs_alt = 0.0
    max_abs_vel = 0.0
    drift_samples: list[dict] = []

    for t_sec in common_t:
        a = a_map[t_sec]
        b = t_map[t_sec]
        d_alt = _to_float(a.get("altitudeM")) - _to_float(b.get("altitudeM"))
        d_vel = _to_float(a.get("velocityMs")) - _to_float(b.get("velocityMs"))
        sq_alt += d_alt * d_alt
        sq_vel += d_vel * d_vel
        max_abs_alt = max(max_abs_alt, abs(d_alt))
        max_abs_vel = max(max_abs_vel, abs(d_vel))
        if len(drift_samples) < 8:
            drift_samples.append(
                {
                    "tSec": t_sec,
                    "deltaAltitudeM": d_alt,
                    "deltaVelocityMs": d_vel,
                }
            )

    n = float(len(common_t))
    rmse_alt = math.sqrt(sq_alt / n)
    rmse_vel = math.sqrt(sq_vel / n)

    a_max_q_kpa = _to_float(actual_summary.get("maxQkPa"), 0.0)
    t_max_q_kpa = _to_float(target_summary.get("maxQkPa"), 0.0)

    return {
        "samplesCompared": int(n),
        "timeRangeSec": {"start": common_t[0], "end": common_t[-1]},
        "rmseAltitudeM": rmse_alt,
        "rmseVelocityMs": rmse_vel,
        "maxAbsAltitudeDriftM": max_abs_alt,
        "maxAbsVelocityDriftMs": max_abs_vel,
        "maxQDeltaKPa": a_max_q_kpa - t_max_q_kpa,
        "actualMaxQkPa": a_max_q_kpa,
        "targetMaxQkPa": t_max_q_kpa,
        "driftSamples": drift_samples,
    }


def _load_chunk_registry() -> dict:
    if CHUNK_REGISTRY_PATH.exists():
        with open(CHUNK_REGISTRY_PATH, encoding="utf-8") as fp:
            return json.load(fp)
    return {
