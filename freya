def _chunk_math_stats(args: argparse.Namespace) -> dict:
    if not args.data_file:
        raise ValueError("math.stats requires --data-file")
    rows = _read_csv_rows(args.data_file)
    if not rows:
        raise ValueError("no rows found in data file")
    method = (args.method or "summary").lower()
    if method == "summary":
        values = [float(r[args.value_col]) for r in rows if args.value_col in r and str(r[args.value_col]).strip()]
        if not values:
            raise ValueError(f"value column '{args.value_col}' has no numeric rows")
        return {
            "chunk": "math.stats",
            "method": "summary",
            "count": len(values),
            "mean": statistics.mean(values),
            "stdev": statistics.pstdev(values) if len(values) > 1 else 0.0,
            "min": min(values),
            "max": max(values),
        }
    if method == "regression":
        x = [float(r[args.x_col]) for r in rows if args.x_col in r and args.y_col in r]
        y = [float(r[args.y_col]) for r in rows if args.x_col in r and args.y_col in r]
        if len(x) < 2:
            raise ValueError("regression needs at least 2 rows")
        mx, my = statistics.mean(x), statistics.mean(y)
        den = sum((xi - mx) ** 2 for xi in x)
        if den == 0:
            raise ValueError("x variance is zero; cannot regress")
        slope = sum((xi - mx) * (yi - my) for xi, yi in zip(x, y)) / den
        intercept = my - slope * mx
        return {"chunk": "math.stats", "method": "regression", "slope": slope, "intercept": intercept, "count": len(x)}
    raise ValueError("math.stats supports methods: summary|regression")


def _parse_cashflows(cashflows: str) -> list[float]:
    vals = []
    for part in cashflows.split(","):
        s = part.strip()
        if s:
            vals.append(float(s))
    if not vals:
        raise ValueError("cashflows string is empty")
    return vals


DIASPORA_METHODS = {
    "abacus": {"region": "East Asia", "era": "Ancient-Present", "lineage": "suanpan/soroban positional counting"},
    "lattice": {"region": "India -> Islamic world -> Europe", "era": "Medieval", "lineage": "gelosia lattice multiplication"},
    "vedic": {"region": "South Asia", "era": "Classical-Modern", "lineage": "mental sutra arithmetic"},
    "egyptian": {"region": "Nile civilization", "era": "Ancient", "lineage": "doubling/halving multiplication"},
    "babylonian": {"region": "Mesopotamia", "era": "Ancient", "lineage": "base-60 arithmetic and iterative roots"},
    "chinese-rod": {"region": "East Asia", "era": "Ancient", "lineage": "rod numeral place-value operations"},
    "yoruba-base20": {"region": "West Africa", "era": "Historical-Modern", "lineage": "vigesimal decomposition"},
    "mayan-base20": {"region": "Mesoamerica", "era": "Classical", "lineage": "vigesimal dot-bar arithmetic"},
    "incan-quipu": {"region": "Andean", "era": "Pre-Columbian", "lineage": "knot-string accounting abstraction"},
    "islamic-algebra": {"region": "MENA", "era": "Golden Age", "lineage": "al-jabr balancing transformations"},
}


def _to_base20(n: int) -> list[int]:
    n = abs(n)
    if n == 0:
        return [0]
    out = []
    while n > 0:
        out.append(n % 20)
        n //= 20
    return list(reversed(out))


def _lattice_multiply_steps(a: int, b: int) -> list[str]:
    a_digits = [int(ch) for ch in str(abs(a))]
    b_digits = [int(ch) for ch in str(abs(b))]
    steps = [f"grid {len(b_digits)}x{len(a_digits)} for {a} x {b}"]
    diag = [0] * (len(a_digits) + len(b_digits))
    for r, bd in enumerate(reversed(b_digits)):
        row = []
        for c, ad in enumerate(reversed(a_digits)):
            p = ad * bd
            row.append(f"{ad}x{bd}={p:02d}")
            diag[r + c] += p
        steps.append("row " + ", ".join(row))
    carry = 0
    out = []
    for val in diag:
        total = val + carry
        out.append(total % 10)
        carry = total // 10
    while carry:
        out.append(carry % 10)
        carry //= 10
    steps.append("diagonal sum digits (low->high): " + ",".join(str(x) for x in out))
    return steps


def _egyptian_multiply_steps(a: int, b: int) -> list[str]:
    left = 1
    right = abs(a)
    target = abs(b)
    selected = []
    steps = [f"target multiply {a} x {b}"]
    while left <= target:
        keep = (target & left) == left
        steps.append(f"{left:>5} | {right:>8} {'*' if keep else ''}")
        if keep:
            selected.append(right)
        left <<= 1
        right <<= 1
    steps.append(f"sum selected = {sum(selected)}")
    return steps


def _run_diaspora_math(method: str, op: str, a: float, b: float | None) -> dict:
    m = method.strip().lower()
    if m not in DIASPORA_METHODS:
        raise ValueError(f"unsupported diaspora method '{method}'")
    op = op.strip().lower()

    if op == "sqrt":
        n = a
        if n < 0:
            raise ValueError("sqrt requires non-negative a")
        if m == "babylonian":
            x = max(1.0, n / 2.0)
            steps = [f"x0={x}"]
            for i in range(8):
                x = 0.5 * (x + n / x) if x != 0 else 0.0
                steps.append(f"x{i+1}={x}")
            result = x
        else:
            result = math.sqrt(n)
            steps = [f"{m} maps sqrt via modern fallback for interoperability"]
    else:
        if b is None:
            raise ValueError(f"operation '{op}' requires --b")
        if op == "add":
            result = a + b
        elif op == "sub":
            result = a - b
        elif op == "mul":
            result = a * b
        elif op == "div":
            if b == 0:
                raise ValueError("division by zero")
            result = a / b
        else:
            raise ValueError("supported ops: add|sub|mul|div|sqrt")

        if m == "abacus":
            steps = [f"set {a} on lower deck", f"{op} with {b} using carry/borrow beads", f"readout={result}"]
        elif m == "lattice" and op == "mul":
            steps = _lattice_multiply_steps(int(round(a)), int(round(b)))
        elif m == "egyptian" and op == "mul":
            steps = _egyptian_multiply_steps(int(round(a)), int(round(b)))
        elif m in {"yoruba-base20", "mayan-base20"}:
            aa = _to_base20(int(round(a)))
            bb = _to_base20(int(round(b)))
            rr = _to_base20(int(round(result)))
            steps = [f"a20={aa}", f"b20={bb}", f"r20={rr}"]
        elif m == "incan-quipu":
            steps = [f"encode {a} and {b} knot clusters", f"apply {op} through positional cords", f"decode={result}"]
        else:
            steps = [f"{m} {op} transformation", f"result={result}"]

    meta = DIASPORA_METHODS[m]
    return {
        "method": m,
        "operation": op,
        "inputs": {"a": a, "b": b},
        "result": result,
        "history": meta,
        "steps": steps,
    }


def _chunk_math_diaspora(args: argparse.Namespace) -> dict:
    a = float(args.a_value)
    b = None if args.b_value is None else float(args.b_value)
    payload = _run_diaspora_math(args.diaspora_method, args.operation, a, b)
    payload["chunk"] = "math.diaspora"
    payload["availableMethods"] = sorted(DIASPORA_METHODS.keys())
    return payload


def _chunk_history_livecalc(args: argparse.Namespace) -> dict:
    events = []
    if args.input:
        raw = _load_telemetry_input(args.input, args.input_format)
        for i, row in enumerate(raw):
            if not isinstance(row, dict):
                continue
            method = str(row.get("method", args.diaspora_method))
            op = str(row.get("operation", row.get("op", args.operation)))
            a = _to_float(row.get("a"), _to_float(row.get("value"), 0.0))
            b_raw = row.get("b")
            b = None if b_raw is None or str(b_raw).strip() == "" else _to_float(b_raw, 0.0)
            calc = _run_diaspora_math(method, op, a, b)
            calc["eventIndex"] = i
            calc["eventLabel"] = str(row.get("label", f"event-{i}"))
            events.append(calc)
    else:
        a = float(args.a_value)
        b = None if args.b_value is None else float(args.b_value)
        calc = _run_diaspora_math(args.diaspora_method, args.operation, a, b)
        calc["eventIndex"] = 0
        calc["eventLabel"] = args.history_label or "live"
        events.append(calc)

    timeline = []
    for i, evt in enumerate(events):
        hist = evt.get("history", {})
        timeline.append(
            {
                "t": i,
                "label": evt.get("eventLabel"),
                "method": evt.get("method"),
                "operation": evt.get("operation"),
                "result": evt.get("result"),
                "region": hist.get("region"),
                "era": hist.get("era"),
                "lineage": hist.get("lineage"),
            }
        )
    return {
        "chunk": "history.livecalc",
        "status": "PASS",
        "count": len(events),
        "timeline": timeline,
        "events": events,
    }


def _chunk_econ_finance(args: argparse.Namespace) -> dict:
    flows = _parse_cashflows(args.cashflows)
    rate = float(args.rate)
    npv = 0.0
    for t, cf in enumerate(flows):
        npv += cf / ((1 + rate) ** t)
    out = {"chunk": "econ.finance", "method": "npv", "rate": rate, "cashflows": flows, "npv": npv}
    if args.include_irr:
        guess = 0.1
        for _ in range(100):
            f = sum(cf / ((1 + guess) ** t) for t, cf in enumerate(flows))
            df = sum((-t * cf) / ((1 + guess) ** (t + 1)) for t, cf in enumerate(flows) if t > 0)
            if abs(df) < 1e-12:
                break
            guess = guess - f / df
        out["irrApprox"] = guess
    return out


def _chunk_docker_build(args: argparse.Namespace) -> dict:
    docker_bin = shutil.which("docker")
    if not docker_bin:
        return {"chunk": "docker.build", "status": "WARN", "message": "docker binary not found on PATH"}
    cmd = [docker_bin, "build", "-t", args.image_tag, args.context_dir]
    if args.dry_run:
        return {"chunk": "docker.build", "status": "PASS", "dryRun": True, "command": cmd}
    proc = subprocess.run(cmd, capture_output=True, text=True, check=False)
    return {
        "chunk": "docker.build",
        "status": "PASS" if proc.returncode == 0 else "FAIL",
        "returnCode": proc.returncode,
        "command": cmd,
        "stdoutTail": proc.stdout[-2000:],
        "stderrTail": proc.stderr[-2000:],
    }


