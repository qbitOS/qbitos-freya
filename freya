            target_rows, target_summary = _annotate_telemetry_rows(
                rows=raw_target,
                step_sec=max(0.001, args.step_sec),
                maxq_start_sec=args.phase_maxq_start_sec,
                maxq_end_sec=args.phase_maxq_end_sec,
                meco_sec=args.phase_meco_sec,
                seco_sec=args.phase_seco_sec,
            )
            report = _compare_telemetry(
                actual_rows=actual_rows,
                target_rows=target_rows,
                actual_summary=actual_summary,
                target_summary=target_summary,
            )
            print(json.dumps(report, indent=2))
            return 0
        except Exception as exc:  # noqa: BLE001
            print(f"error: {exc}", file=sys.stderr)
            return 1
    if args.cmd == "quantum":
        if args.quantum_cmd == "run":
            try:
                print(
                    json.dumps(
                        _run_quantum_program(
                            qubits=args.qubits,
                            program=args.program,
                            shots=max(0, args.shots),
                        ),
                        indent=2,
                    )
                )
                return 0
            except Exception as exc:  # noqa: BLE001
                print(f"error: {exc}", file=sys.stderr)
                return 1

    return 1


