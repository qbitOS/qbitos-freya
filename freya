def _chunk_quantum_algorithm(args: argparse.Namespace) -> dict:
    name = (args.name or "").strip().lower()
    if name == "grover":
        # Interpret --number for Grover as search-space size N when provided.
        # Current portable implementation supports N=4 (2 qubits) with target 0..3.
        n = int(args.number) if args.number else 4
        if n != 4:
            raise ValueError("grover currently supports --number 4 (2-qubit search space)")
        target_idx = int(str(args.target)) if args.target is not None else int(args.marked_state, 2)
        if not (0 <= target_idx <= 3):
            raise ValueError("grover target must be in range 0..3 for current implementation")
        target_bits = format(target_idx, "02b")

        # Oracle for arbitrary 2-bit target: X on 0-bits -> CZ(11) -> undo X.
        ops = []
        ops.extend(["h 0", "h 1"])
        if target_bits[0] == "0":
            ops.append("x 0")
        if target_bits[1] == "0":
            ops.append("x 1")
        ops.extend(["h 1", "cx 0 1", "h 1"])
        if target_bits[0] == "0":
            ops.append("x 0")
        if target_bits[1] == "0":
            ops.append("x 1")
        # Diffuser (2-qubit)
        ops.extend(["h 0", "h 1", "x 0", "x 1", "h 1", "cx 0 1", "h 1", "x 0", "x 1", "h 0", "h 1", "measure"])
        program = "; ".join(ops)
        return {
            "chunk": "quantum.algorithm",
            "algorithm": "grover",
            "target": target_idx,
            "note": "Portable 2-qubit Grover with configurable target index.",
            "result": _run_quantum_program(2, program, max(0, args.shots)),
        }
    if name == "shor":
        n = int(args.number)
        if n < 2:
            raise ValueError("shor requires --number >= 2")
        factor = 1
        for i in range(2, int(math.sqrt(n)) + 1):
            if n % i == 0:
                factor = i
                break
        if factor == 1:
            return {
                "chunk": "quantum.algorithm",
                "algorithm": "shor",
                "status": "INCONCLUSIVE",
                "number": n,
                "message": "No non-trivial factor found (likely prime) in classical fallback.",
            }
        return {
            "chunk": "quantum.algorithm",
            "algorithm": "shor",
            "status": "PASS",
            "number": n,
            "factors": [factor, n // factor],
            "message": "Classical fallback factorization for CLI portability.",
        }
    raise ValueError(f"unsupported quantum algorithm '{name}'")


def _chunk_gis_convert(args: argparse.Namespace) -> dict:
    from_crs = (args.from_crs or "").upper()
    to_crs = (args.to_crs or "").upper()
    lat = float(args.lat)
    lon = float(args.lon)
    if from_crs == "WGS84" and to_crs in {"WEBMERCATOR", "EPSG:3857"}:
        r = 6378137.0
        x = math.radians(lon) * r
        y = math.log(math.tan((math.pi / 4) + (math.radians(lat) / 2))) * r
        return {"chunk": "gis.convert", "from": from_crs, "to": to_crs, "x": x, "y": y}
    if from_crs == "WGS84" and to_crs == "UTM":
        zone = int((lon + 180) / 6) + 1
        return {
            "chunk": "gis.convert",
            "from": "WGS84",
            "to": "UTM",
            "zone": zone,
            "hemisphere": "N" if lat >= 0 else "S",
            "note": "Use pyproj for survey-grade UTM precision; this CLI chunk is a routing stub.",
        }
    raise ValueError("supported conversions: WGS84->WEBMERCATOR and WGS84->UTM")


