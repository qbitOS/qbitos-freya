def _router_record_eval(rows: list[dict]) -> None:
    metrics = _router_metrics_load()
    backends = metrics.get("backends", {})
    if not isinstance(backends, dict):
        backends = {}
    for row in rows:
        if not isinstance(row, dict):
            continue
        bk = str(row.get("backend", "")).strip().lower()
        if not bk:
            continue
        slot = backends.get(bk, {"attempts": 0, "ok": 0, "latencyMsAvg": 0.0})
        attempts = int(slot.get("attempts", 0)) + 1
        ok_prev = int(slot.get("ok", 0))
        ok_new = ok_prev + (1 if bool(row.get("ok")) else 0)
        prev_avg = float(slot.get("latencyMsAvg", 0.0))
        lat = float(row.get("latencyMs", 0.0))
        new_avg = ((prev_avg * max(0, attempts - 1)) + lat) / max(1, attempts)
        slot.update({"attempts": attempts, "ok": ok_new, "latencyMsAvg": new_avg, "updatedAt": _now_iso()})
        backends[bk] = slot
    metrics["backends"] = backends
    _router_metrics_save(metrics)


def _router_backend_score(backend: str, item: dict, metrics: dict) -> float:
    if item.get("status") != "ok":
        return -1e9
    mb = metrics.get("backends", {}) if isinstance(metrics, dict) else {}
    slot = mb.get(backend, {}) if isinstance(mb, dict) else {}
    attempts = int(slot.get("attempts", 0))
    ok = int(slot.get("ok", 0))
    success_rate = (ok / attempts) if attempts > 0 else 0.5
    latency = float(slot.get("latencyMsAvg", 1000.0))
    # Higher is better: prioritize success, then lower latency.
    return (success_rate * 1000.0) - latency


def _chat_with_session(
    query: str,
    backend: str,
    model: str | None,
    family: str | None,
    session_id: str | None,
    history_n: int,
    use_rag: bool,
    rag_top_k: int,
) -> tuple[str, str | None]:
    prompt = query
    sid = session_id.strip() if session_id else ""
    if sid:
        _ensure_state_dir()
        FREYA_SESSION_DIR.mkdir(parents=True, exist_ok=True)
        sp = _session_path(sid)
        payload = _load_json_file(sp, {"sessionId": sid, "turns": [], "status": "active"})
        if isinstance(payload, dict) and str(payload.get("status", "active")) not in {"active", "open"}:
            raise ValueError(f"session '{sid}' is closed/archived")
        turns = payload.get("turns", []) if isinstance(payload, dict) else []
        if not isinstance(turns, list):
            turns = []
        recent = turns[-max(0, history_n) :]
        history_lines = []
        for t in recent:
            if isinstance(t, dict):
                history_lines.append(f"USER: {t.get('user', '')}")
                history_lines.append(f"ASSISTANT: {t.get('assistant', '')}")
        if history_lines:
            prompt = f"Session context:\n" + "\n".join(history_lines) + f"\n\nNew user query:\n{query}"
    if use_rag:
        rag = _rag_query(query, rag_top_k)
        if rag.get("results"):
            ctx = "\n".join([f"- {r['path']}: {r['snippet']}" for r in rag["results"] if isinstance(r, dict)])
            prompt = f"{prompt}\n\nRAG context:\n{ctx}"
    answer = chat_conversion(prompt, backend=backend, model=model, family=family)
    if sid:
        sp = _session_path(sid)
        payload = _load_json_file(sp, {"sessionId": sid, "turns": [], "status": "active"})
        turns = payload.get("turns", []) if isinstance(payload, dict) else []
        if not isinstance(turns, list):
            turns = []
        turns.append({"t": _now_iso(), "user": query, "assistant": answer})
        payload["turns"] = turns
        payload["status"] = payload.get("status", "active")
        payload["updatedAt"] = _now_iso()
        _save_json_file(sp, payload)
    return answer, sid or None


def _router_choose(task: str, family: str | None = None) -> dict:
    policy = _load_json_file(FREYA_ROUTER_POLICY_PATH, _default_router_policy())
    if not isinstance(policy, dict):
        policy = _default_router_policy()
    task_order = policy.get("taskOrder", {})
    order = task_order.get(task, task_order.get("chat", ["lmstudio", "ollama", "ugrad", "huggingface", "mistral"]))
    inventory = models_inventory("all")
    metrics = _router_metrics_load()
    tried = []
    ranked = []
    for backend in order:
        item = inventory.get(backend, {})
        score = _router_backend_score(backend, item, metrics)
        row = {"backend": backend, "status": item.get("status", "unknown"), "models": item.get("models", [])[:5], "score": score}
        tried.append(row)
        if item.get("status") == "ok":
            ranked.append(row)
    if ranked:
        ranked.sort(key=lambda x: float(x.get("score", -1e9)), reverse=True)
        chosen = ranked[0]
        model = _resolve_model(chosen["backend"], None, family)
        return {"status": "PASS", "task": task, "backend": chosen["backend"], "model": model, "candidates": tried}
    raise RuntimeError(f"no healthy backend for task '{task}'")


def _agent_memory_write(agent: str, key: str, value: str) -> dict:
    _ensure_state_dir()
    payload = _load_json_file(FREYA_AGENT_MEMORY_PATH, {"agents": {}})
    if not isinstance(payload, dict):
        payload = {"agents": {}}
    agents = payload.get("agents", {})
    if not isinstance(agents, dict):
        agents = {}
    slot = agents.get(agent, {})
    if not isinstance(slot, dict):
        slot = {}
    slot[key] = {"value": value, "updatedAt": _now_iso()}
    agents[agent] = slot
    payload["agents"] = agents
    _save_json_file(FREYA_AGENT_MEMORY_PATH, payload)
