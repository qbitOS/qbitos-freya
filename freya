    # Compatibility route: allow telemetry compare shape through chunk runner.
    if args.actual and args.target:
        raw_actual = _load_telemetry_input(args.actual, args.format)
        raw_target = _load_telemetry_input(args.target, args.format)
        actual_rows, actual_summary = _annotate_telemetry_rows(
            rows=raw_actual,
            step_sec=max(0.001, args.step_sec),
            maxq_start_sec=args.phase_maxq_start_sec,
            maxq_end_sec=args.phase_maxq_end_sec,
            meco_sec=args.phase_meco_sec,
            seco_sec=args.phase_seco_sec,
        )
        target_rows, target_summary = _annotate_telemetry_rows(
            rows=raw_target,
            step_sec=max(0.001, args.step_sec),
            maxq_start_sec=args.phase_maxq_start_sec,
            maxq_end_sec=args.phase_maxq_end_sec,
            meco_sec=args.phase_meco_sec,
            seco_sec=args.phase_seco_sec,
