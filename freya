def _simulate_telemetry(
    duration_s: float,
    dt_s: float,
    dry_mass_kg: float,
    fuel_mass_kg: float,
    thrust_n: float,
    isp_s: float,
    drag_cd: float,
    area_m2: float,
    throttle: float,
    live: bool,
) -> tuple[list[dict], dict]:
    t = 0.0
    altitude_m = 0.0
    velocity_m_s = 0.0
    fuel_kg = max(0.0, fuel_mass_kg)

    rows: list[dict] = []
    max_q_pa = 0.0
    max_accel_m_s2 = 0.0
    g0 = 9.80665
    last_mass_kg = dry_mass_kg + fuel_kg

    while t <= duration_s + 1e-9:
        mass_kg = dry_mass_kg + fuel_kg
        mdot_kg_s = (thrust_n / (isp_s * g0)) if isp_s > 0 else 0.0
        consumed_kg = min(fuel_kg, mdot_kg_s * dt_s * throttle)
        thrust_live_n = thrust_n * throttle if fuel_kg > 0 else 0.0
        fuel_kg -= consumed_kg

        rho = _air_density(altitude_m)
        drag_n = 0.5 * rho * drag_cd * area_m2 * velocity_m_s * abs(velocity_m_s)
        gravity_n = mass_kg * _gravity(altitude_m)
        net_n = thrust_live_n - gravity_n - drag_n
        accel_m_s2 = net_n / mass_kg if mass_kg > 0 else 0.0
        velocity_m_s = velocity_m_s + accel_m_s2 * dt_s
        altitude_m = max(0.0, altitude_m + velocity_m_s * dt_s)
        q_pa = 0.5 * rho * velocity_m_s * velocity_m_s
        mach = velocity_m_s / 340.0
        twr = (thrust_live_n / gravity_n) if gravity_n > 0 else 0.0

        if q_pa > max_q_pa:
            max_q_pa = q_pa
        if abs(accel_m_s2) > max_accel_m_s2:
            max_accel_m_s2 = abs(accel_m_s2)
        last_mass_kg = mass_kg

        rows.append(
            {
                "tSec": round(t, 3),
                "altitudeM": altitude_m,
                "velocityMs": velocity_m_s,
                "massKg": mass_kg,
                "fuelKg": fuel_kg,
                "accelMs2": accel_m_s2,
                "dynamicPressurePa": q_pa,
                "machApprox": mach,
                "twr": twr,
                "thermalLoadProxy": q_pa * max(0.0, mach),
            }
        )
        if live:
            time.sleep(max(0.0, dt_s))
        t += dt_s

    # Tsiolkovsky vacuum estimate with consumed mass.
    initial_mass = dry_mass_kg + fuel_mass_kg
    final_mass = max(dry_mass_kg, last_mass_kg)
    dv_vac_m_s = isp_s * g0 * math.log(initial_mass / final_mass) if final_mass > 0 and initial_mass > final_mass else 0.0
    summary = {
        "durationSec": duration_s,
        "stepSec": dt_s,
        "maxQPa": max_q_pa,
        "maxQkPa": max_q_pa / 1000.0,
        "maxAccelMs2": max_accel_m_s2,
        "maxAccelG": max_accel_m_s2 / g0,
        "deltaVVacuumMs": dv_vac_m_s,
        "controlEnvelope": "DAC/Prefix/Steno/Iron-Line/Preflight/search-history controls",
    }
    return rows, summary


def _apply_single_qubit_gate(state: list[complex], qubits: int, qubit: int, gate: list[list[complex]]) -> list[complex]:
    out = state[:]
    step = 1 << qubit
    span = step << 1
    size = 1 << qubits
    for base in range(0, size, span):
        for i in range(step):
            i0 = base + i
            i1 = i0 + step
            a0 = state[i0]
            a1 = state[i1]
            out[i0] = gate[0][0] * a0 + gate[0][1] * a1
            out[i1] = gate[1][0] * a0 + gate[1][1] * a1
    return out


def _apply_cx(state: list[complex], qubits: int, control: int, target: int) -> list[complex]:
    if control == target:
        raise ValueError("cx requires different control and target qubits")
    size = 1 << qubits
    out = state[:]
    control_mask = 1 << control
    target_mask = 1 << target
    for i in range(size):
        if i & control_mask and not (i & target_mask):
            j = i | target_mask
            out[i], out[j] = out[j], out[i]
    return out


def _run_quantum_program(qubits: int, program: str, shots: int) -> dict:
    if qubits < 1 or qubits > 10:
        raise ValueError("qubits must be between 1 and 10")
    state: list[complex] = [0j] * (1 << qubits)
    state[0] = 1 + 0j

    ops = [chunk.strip() for chunk in program.replace("\n", ";").split(";") if chunk.strip()]
    for op in ops:
        parts = op.split()
        gate = parts[0].lower()
        if gate in {"h", "x", "y", "z", "s", "t"}:
            if len(parts) != 2:
                raise ValueError(f"{gate} expects 1 qubit argument")
            q = int(parts[1])
            if not (0 <= q < qubits):
                raise ValueError(f"qubit index out of range: {q}")
            if gate == "h":
                inv = 1 / math.sqrt(2)
                g = [[inv, inv], [inv, -inv]]
            elif gate == "x":
                g = [[0, 1], [1, 0]]
            elif gate == "y":
                g = [[0, -1j], [1j, 0]]
            elif gate == "z":
                g = [[1, 0], [0, -1]]
            elif gate == "s":
                g = [[1, 0], [0, 1j]]
            else:  # t
                g = [[1, 0], [0, cmath.exp(1j * math.pi / 4)]]
            state = _apply_single_qubit_gate(state, qubits, q, g)
        elif gate in {"rx", "ry", "rz"}:
            if len(parts) != 3:
                raise ValueError(f"{gate} expects angle_rad and qubit arguments")
            theta = float(parts[1])
            q = int(parts[2])
            if not (0 <= q < qubits):
                raise ValueError(f"qubit index out of range: {q}")
            c = math.cos(theta / 2.0)
            s = math.sin(theta / 2.0)
            if gate == "rx":
                g = [[c, -1j * s], [-1j * s, c]]
            elif gate == "ry":
                g = [[c, -s], [s, c]]
            else:
                g = [[cmath.exp(-1j * theta / 2.0), 0], [0, cmath.exp(1j * theta / 2.0)]]
            state = _apply_single_qubit_gate(state, qubits, q, g)
        elif gate == "cx":
            if len(parts) != 3:
                raise ValueError("cx expects control target")
            control = int(parts[1])
            target = int(parts[2])
            if not (0 <= control < qubits and 0 <= target < qubits):
                raise ValueError("cx qubit index out of range")
            state = _apply_cx(state, qubits, control, target)
        elif gate == "measure":
            continue
        else:
            raise ValueError(f"unsupported gate '{gate}'")

    probs = [abs(a) ** 2 for a in state]
    total = sum(probs)
    if total <= 0:
        raise ValueError("invalid quantum state: total probability is zero")
    probs = [p / total for p in probs]

    counts: dict[str, int] = {}
    if shots > 0:
        samples = random.choices(range(len(probs)), weights=probs, k=shots)
        for idx in samples:
            bitstr = format(idx, f"0{qubits}b")
            counts[bitstr] = counts.get(bitstr, 0) + 1

    amplitudes = {}
    for i, amp in enumerate(state):
        if abs(amp) > 1e-9:
            amplitudes[format(i, f"0{qubits}b")] = {"re": amp.real, "im": amp.imag}

    z_expectation = {}
    for q in range(qubits):
        exp_z = 0.0
        mask = 1 << q
        for i, p in enumerate(probs):
            exp_z += p if (i & mask) == 0 else -p
        z_expectation[f"q{q}"] = exp_z

    return {
        "qubits": qubits,
        "program": ops,
        "amplitudes": amplitudes,
        "probabilities": {format(i, f"0{qubits}b"): probs[i] for i in range(len(probs)) if probs[i] > 1e-9},
        "shots": shots,
        "counts": counts,
        "expectationZ": z_expectation,
    }


def main() -> int:
    ap = argparse.ArgumentParser(description="Freya CLI for math, conversions, and multi-backend chat")
    sub = ap.add_subparsers(dest="cmd", required=True)

    # Math commands
    math_parser = sub.add_parser("math", help="Math and data economics")
