def _find_chunk(chunk_id: str, registry: dict) -> dict | None:
    for item in registry.get("chunks", []):
        if isinstance(item, dict) and item.get("id") == chunk_id:
            return item
    return None


def _chunk_models_doctor() -> dict:
    inventory = models_inventory("all")
    healthy = 0
    total = 0
    for backend, info in inventory.items():
        total += 1
        if isinstance(info, dict) and info.get("status") == "ok":
            healthy += 1
    return {
        "chunk": "models.doctor",
        "status": "PASS" if healthy == total else "WARN",
        "healthyBackends": healthy,
        "totalBackends": total,
        "inventory": inventory,
    }


def _chunk_telemetry_alert(args: argparse.Namespace) -> dict:
    if not args.input:
        raise ValueError("telemetry.alert requires --input")
    raw_rows = _load_telemetry_input(args.input, args.input_format)
    rows, summary = _annotate_telemetry_rows(
        rows=raw_rows,
        step_sec=max(0.001, args.step_sec),
        maxq_start_sec=args.phase_maxq_start_sec,
        maxq_end_sec=args.phase_maxq_end_sec,
        meco_sec=args.phase_meco_sec,
        seco_sec=args.phase_seco_sec,
    )
    validation = _validate_telemetry(
        rows=rows,
        summary=summary,
        max_q_kpa=args.max_q_kpa,
        max_accel_g=args.max_accel_g,
        min_twr=args.min_twr_powered,
        max_thermal=args.max_thermal_proxy,
    )
    severity = "INFO" if validation["status"] == "PASS" else "ALERT"
    return {
        "chunk": "telemetry.alert",
        "severity": severity,
        "status": validation["status"],
        "summary": summary,
        "violationCount": validation["violationCount"],
        "violations": validation["violations"],
    }


