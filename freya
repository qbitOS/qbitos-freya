        raise ValueError(reason)
    deps = []
    deps_csv = str(getattr(args, "plugin_deps", "") or "").strip()
    if deps_csv:
        deps = [d.strip() for d in deps_csv.split(",") if d.strip()]
    else:
        try:
            resolved = _plugin_resolve(plugin_name, include_optional=False)
            deps = [d for d in resolved.get("installOrder", []) if d != plugin_name]
        except Exception:  # noqa: BLE001
            deps = []
    registry = _load_json_file(FREYA_PLUGIN_REGISTRY_PATH, {"plugins": []})
    plugins = registry.get("plugins", []) if isinstance(registry, dict) else []
    for p in plugins:
        if isinstance(p, dict) and p.get("name") == plugin_name:
            return {"chunk": "plugins.install", "status": "PASS", "message": "already installed", "plugin": p}
    missing = []
    if deps:
        installed = {str(p.get("name")) for p in plugins if isinstance(p, dict)}
        missing = [d for d in deps if d not in installed]
    plugin = {
        "name": plugin_name,
        "version": str(getattr(args, "plugin_version", "0.1.0")),
        "sandbox": sandbox,
        "dependencies": deps,
        "dependencyStatus": "missing" if missing else "ok",
        "missingDependencies": missing,
        "installedAtEpochSec": int(time.time()),
    }
    plugins.append(plugin)
    _save_json_file(FREYA_PLUGIN_REGISTRY_PATH, {"plugins": plugins})
    return {"chunk": "plugins.install", "status": "PASS", "plugin": plugin}


