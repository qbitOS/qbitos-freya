def _chunk_bench_run(args: argparse.Namespace) -> dict:
    cmd = shlex.split(args.bench_command)
    if not cmd:
        raise ValueError("bench command is empty")
    durations = []
    for _ in range(max(1, args.iterations)):
        t0 = time.perf_counter()
        proc = subprocess.run(cmd, capture_output=True, text=True, check=False)
        dt_ms = (time.perf_counter() - t0) * 1000.0
        durations.append({"ms": dt_ms, "returnCode": proc.returncode})
    ms_values = [d["ms"] for d in durations]
    return {
        "chunk": "bench.run",
        "command": cmd,
        "iterations": len(durations),
        "minMs": min(ms_values),
        "maxMs": max(ms_values),
        "meanMs": statistics.mean(ms_values),
        "p95Ms": sorted(ms_values)[int(0.95 * (len(ms_values) - 1))],
    }


