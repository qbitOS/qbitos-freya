def _enterprise_eval(prompt: str, backends_csv: str, family: str | None = None) -> dict:
    backends = [b.strip().lower() for b in backends_csv.split(",") if b.strip()]
    rows = []
    for bk in backends:
        t0 = time.perf_counter()
        out = chat_conversion(prompt, backend=bk, model=None, family=family)
        dt_ms = (time.perf_counter() - t0) * 1000.0
        ok = not out.startswith("Error:")
        rows.append(
            {
                "backend": bk,
                "ok": ok,
                "latencyMs": dt_ms,
                "outputPreview": out[:220],
                "outputLength": len(out),
            }
        )
    ok_rows = [r for r in rows if r["ok"]]
    winner = min(ok_rows, key=lambda x: x["latencyMs"]) if ok_rows else None
    _router_record_eval(rows)
    return {"prompt": prompt, "rows": rows, "winner": winner}


