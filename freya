                base = os.getenv("LOCAL_LLM_BASE_URL", "http://127.0.0.1:1234/v1")
                key = os.getenv("LOCAL_LLM_API_KEY", "lm-studio")
                out[bk] = {"status": "ok", "models": _list_openai_compat_models(base, key)}
            elif bk == "ollama":
                base = os.getenv("OLLAMA_BASE_URL", "http://127.0.0.1:11434")
                out[bk] = {"status": "ok", "models": _list_ollama_models(base)}
