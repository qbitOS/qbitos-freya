    telemetry_compare.add_argument("--step-sec", type=float, default=1.0)
    telemetry_compare.add_argument("--phase-maxq-start-sec", type=float, default=35.0)
    telemetry_compare.add_argument("--phase-maxq-end-sec", type=float, default=65.0)
    telemetry_compare.add_argument("--phase-meco-sec", type=float, default=None)
    telemetry_compare.add_argument("--phase-seco-sec", type=float, default=None)

